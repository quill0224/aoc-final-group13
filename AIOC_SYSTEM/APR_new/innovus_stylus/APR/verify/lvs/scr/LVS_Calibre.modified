DEVICE MN(nchpd_8trpsr_mac) ngate_pd_8trpsr_mac ngate_pd_8trpsr_mac(G) tndiff(S) tndiff(D) psub(B) <nthin>  <ODs> netlist model nchpd_8trpsr_mac netlist element "X" [
   property nfin,L
   #IFDEF EXTRACT_W
   ,W
   #ENDIF
   SCALE = PRESCALE
   W=(perimeter_coincide(ngate_pd_8trpsr_mac, tndiff ) + perimeter_inside(ngate_pd_8trpsr_mac, tndiff)) / 2
   L=area(ngate_pd_8trpsr_mac) / W
   nfin = count(ODs)
   W = (FIN_WIDTH + ( nfin - 1) * FIN_PITCH) * 1e-6
]

