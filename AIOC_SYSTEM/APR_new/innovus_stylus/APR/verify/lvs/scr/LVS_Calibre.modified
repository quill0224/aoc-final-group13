   snet = PIN_NET(s)
   dnet = PIN_NET(d)
   net1 = DFM_NUM_VAL( gate_COR, "NET_1" )
   net2 = DFM_NUM_VAL( gate_COR, "NET_2" )
   if ( snet == net1 ) {
      is_rotated = 0
   } else {
      is_rotated = 1
   }
