var_nw_rf_seed_ndnw_all = var_nw_rfa NOT DNW 
var_nw_rf_seed_ndnw = var_nw_rf_seed_ndnw_all NOT INTERACT RFDMY_mmW  //  RF dmos nmoscap core 0.8v w/o DNW

