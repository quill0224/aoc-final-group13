rfres_SOB_base = RH_TNi_all AND RPDMY 
v_dir_rfres = RPDMY NOT rfres_SOB_base 

//***** Define connectivity/via layer -- n_gptap_lvt ****
n_gptap_lvt = gptap AND n_gpoly_lvt_all 

//***** Define connectivity/via layer -- mom5p_sf ****
