all_mos_gates = vargt_18 OR (vargt OR (ppode_lnvt_mac_gate OR (npode_lnvt_mac_gate OR (pgate_18ud12_pode3t OR (pgate_18ud15_pode3t OR (pgate_18_pode3t OR (puvgate_pode3t OR (plvhfmaxgate_pode3t OR (plvgate_pode3t OR (pgate_pode3t OR (ngate_18ud12_pode3t OR (ngate_18ud15_pode3t OR (ngate_18_pode3t OR (ppode_hvt_mac_gate OR (npode_hvt_mac_gate OR (nhftuvgate_pode3t OR (nuvgate_pode3t OR (nlvgate_pode3t OR (ngate_pode3t OR (pch_mpodelnvt_mac_gate OR (nch_mpodelnvt_mac_gate OR (puvgate_mpode_mac OR (plvhfmaxgate_mpode_mac OR (plvgate_mpode_mac OR (pgate_mpode_mac OR (pch_mpodehvt_mac_gate OR (nch_mpodehvt_mac_gate OR (nhftuvgate_mpode_mac OR (nuvgate_mpode_mac OR (nlvgate_mpode_mac OR (ngate_mpode_mac OR (pgate_pu_dpfsr_mac OR (ngate_pd_dpfsr_mac OR (ngate_pg_dpfsr_mac OR (ngate_pd_hs8trpsr_mac OR (ngate_pg_hs8trpsr_mac OR (pgate_pu_hs8tsr_mac OR (ngate_pd_hs8tsr_mac OR (ngate_pg_hs8tsr_mac OR (ngate_pd_hc8trpsr_mac OR (ngate_pg_hc8trpsr_mac OR (pgate_pu_hc8tsr_mac OR (ngate_pd_hc8tsr_mac OR (ngate_pg_hc8tsr_mac OR (ngate_pd_8trpsr_mac OR (ngate_pg_8trpsr_mac OR (pgate_pu_8tsr_mac OR (ngate_pd_8tsr_mac OR (ngate_pg_8tsr_mac OR (pgate_pu_hpsr_mac OR (ngate_pd_hpsr_mac OR (ngate_pg_hpsr_mac OR (pgate_pu_hcsr_mac OR (ngate_pd_hcsr_mac OR (ngate_pg_hcsr_mac OR (pgate_pu_shcsr_mac OR (ngate_pd_shcsr_mac OR (ngate_pg_shcsr_mac OR (pgate_pu_hdsr_mac OR (ngate_pd_hdsr_mac OR (ngate_pg_hdsr_mac OR (pgate_pu_shdsr_mac OR (ngate_pd_shdsr_mac OR (ngate_pg_shdsr_mac OR (pgate_hv18_mac OR (ngate_hv18_mac OR (pch_lnvt_mac_gate OR (nch_lnvt_dnw_mac_gate OR (nch_lnvt_mac_gate OR (pgate_18ud12_mac OR (pgate_18ud15_mac OR (pgate_18_mac OR (pch_hvt_mac_gate OR (puvgate_mac OR (plvlrgate_mac OR (plvgate_mac OR (pgate_mac OR (dngate_hia18_mac OR (dngate_18ud12_mac OR (dngate_18ud15_mac OR (dngate_18_mac OR (ngate_hia18_mac OR (ngate_18ud12_mac OR (ngate_18ud15_mac OR (ngate_18_mac OR (nrhftuvgate_mac OR (nruvgate_mac OR (n1lvgate_mac OR (nrgate_mac OR (nch_hvt_dnw_mac_gate OR (nhftuvgate_mac OR (nch_hvt_mac_gate OR (nuvgate_mac OR (ngate_mac OR nlvgate_mac))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))
tndiff_gates = tndiff_all INTERACT all_mos_gates
tpdiff_gates = tpdiff_all INTERACT all_mos_gates

all_diode_form = COPY nwdio_r
tndiff_diode = tndiff_all INTERACT all_diode_form
tpdiff_diode = tpdiff_all INTERACT all_diode_form

all_rdiff_form = var_nw_rf18_110g OR (var_nw_rf_seed_110g OR (var_nw_rf18_ndnw_110g OR (var_nw_rf_seed_ndnw_110g OR (var_nw_rf18 OR (var_nw_rf_seed OR (var_nw_rf18_ndnw OR (var_nw_rf_seed_ndnw OR (ppode_lnvt_mac_reg OR (npode_lnvt_mac_reg OR (pgate_18ud12_pode3t_edge OR (pgate_18ud15_pode3t_edge OR (pgate_18_pode3t_edge OR (puvgate_pode3t_edge OR (plvhfmaxgate_pode3t_edge OR (plvgate_pode3t_edge OR (pgate_pode3t_edge OR (ngate_18ud12_pode3t_edge OR (ngate_18ud15_pode3t_edge OR (ngate_18_pode3t_edge OR (ppode_hvt_mac_reg OR (npode_hvt_mac_reg OR (nhftuvgate_pode3t_edge OR (nuvgate_pode3t_edge OR (ngate_pode3t_edge OR nlvgate_pode3t_edge))))))))))))))))))))))))
tndiff_r = tndiff_all INTERACT all_rdiff_form
tpdiff_r = tpdiff_all INTERACT all_rdiff_form

tndiff_cut = d_tndiff_hv OR (d_tndiff OR s_tndiff)
tpdiff_cut = d_tpdiff_hv OR (d_tpdiff OR s_tpdiff)
tndiff_RC = tndiff_all NOT (((tndiff_gates OR tndiff_diode) OR tndiff_r) OR tndiff_cut)
tndiff = tndiff_all NOT ( tndiff_RC OR tndiff_cut )

tpdiff_RC = tpdiff_all NOT (((tpdiff_gates OR tpdiff_diode) OR tpdiff_r) OR tpdiff_cut)
tpdiff = tpdiff_all NOT ( tpdiff_RC OR tpdiff_cut )


