   TOP_EXT = 0
   BOT_EXT = NMOS_BOT_EXT
   SCALE = PRESCALE
   W = (perimeter_coincide(nlvgate_mpode_mac, tndiff ) + perimeter_inside(nlvgate_mpode_mac, tndiff)) / 2
