//   cfmom_wo_p80_rf_odd        3T rf fmom p80 wo poly shielding (PW shield) (odd fingers)     ((PSUB*MOMDMY100*M1i*MOMDMY1*M2i*MOMDMY2*M3i*MOMDMY3)*RFDMY-MOMDMY22-MOMDMY27*MOMDMY32*MOMDMYP80*MOMDMY_PLUS*MOMDMY_MINUS-RFDMY_mmW)    
//   cfmom_wo_p80_rf_odd        3T rf fmom p80 wo poly shielding (NTN shield) (odd fingers)    ((NT_N*MOMDMY100*M1i*MOMDMY1*M2i*MOMDMY2*M3i*MOMDMY3)*RFDMY-MOMDMY22-MOMDMY27*MOMDMY33*MOMDMYP80*MOMDMY_PLUS*MOMDMY_MINUS-RFDMY_mmW)    
// 
//   cfmom_wo_p80_rf_odd_110g   3T rf fmom p80 wo poly shielding (NW shield) (odd fingers)     ((NW*MOMDMY100*M1i*MOMDMY1*M2i*MOMDMY2*M3i*MOMDMY3)*RFDMY-MOMDMY22-MOMDMY27*MOMDMY31*MOMDMYP80*MOMDMY_PLUS*MOMDMY_MINUS*RFDMY_mmW)    
//   cfmom_wo_p80_rf_odd_110g   3T rf fmom p80 wo poly shielding (PW shield) (odd fingers)     ((PSUB*MOMDMY100*M1i*MOMDMY1*M2i*MOMDMY2*M3i*MOMDMY3)*RFDMY-MOMDMY22-MOMDMY27*MOMDMY32*MOMDMYP80*MOMDMY_PLUS*MOMDMY_MINUS*RFDMY_mmW)    
//   cfmom_wo_p80_rf_odd_110g   3T rf fmom p80 wo poly shielding (NTN shield) (odd fingers)    ((NT_N*MOMDMY100*M1i*MOMDMY1*M2i*MOMDMY2*M3i*MOMDMY3)*RFDMY-MOMDMY22-MOMDMY27*MOMDMY33*MOMDMYP80*MOMDMY_PLUS*MOMDMY_MINUS*RFDMY_mmW)    
// 
// 
// 
//   cfmom_wo_p80_rf_odd        3T rf fmom p80 wi M1 shielding (odd fingers)      ((MOMDMY100*M1i*M2i*MOMDMY2*M3i*MOMDMY3)*RFDMY-MOMDMY22-MOMDMY27*MOMDMY33*MOMDMYP80*MOMDMY35*MOMDMY_PLUS*MOMDMY_MINUS-RFDMY_mmW)    
// 
//   cfmom_wo_p80_rf_odd_110g   3T rf fmom p80 wi M1 shielding (odd fingers)      ((MOMDMY100*M1i*M2i*MOMDMY2*M3i*MOMDMY3)*RFDMY-MOMDMY22-MOMDMY27*MOMDMY33*MOMDMYP80*MOMDMY35*MOMDMY_PLUS*MOMDMY_MINUS*RFDMY_mmW)    
// 
// 
//   csfmom_2t                  2T small fmom                                     (MOMDMY_SFM*M4i*MOMDMY4*M5i*MOMDMY5*M6i*MOMDMY6*M7i*MOMDMY7*MOMDMY_SFM_P) 
// 
// 
//   spiral_std_mu_z_dm           RF inductor                                       (M9i*INDDMY) 
//   spiral_sym_mu_z_dm           RF inductor                                       (M9i*INDDMY) 
//   spiral_sym_ct_mu_z_a28_dm    RF inductor                                       (M9i*INDDMY*APi*IND_D4) 
// 
// 
//   rhim_rf                         RF High Resistor (TiN) 3T                    (RPDMYi*RH_TN*NW*RFDMY-RFDMY_mmW) 
// 
//   rhim_rf_110g                    RF High Resistor (TiN) 3T                    (RPDMYi*RH_TN*NW*RFDMY*RFDMY_mmW) 
// 
//   rhimw_rf                        RF High Resistor (TiN) 3T                    (RPDMYi-RH_TNi*RH_TNi_S*NW*RFDMY-RFDMY_mmW) 
// 
//   rhimw_rf_110g                   RF High Resistor (TiN) 3T                    (RPDMYi-RH_TNi*RH_TNi_S*NW*RFDMY*RFDMY_mmW) 
// 
// 
//   ----- ----------------------------- ---------------------------------- 
//   * OD    = ODI 
//   * PO    = POI 
//   * p3    = p3i 
//   * PSUB  = BULK 
//   * DNWDMY  = DNW * LVSDMY4 
//   * NGATE = ODI * POI * NP - NW -RFDMY 
//   * PGATE = ODI * POI * PP * NW -RFDMY 
//   * NGATES = ODI * POI * NP - NW 
//   * PGATES = ODI * POI * PP * NW 
//   * SCR_N = SDI_2 * NP 
//   * SCR_P = SDI_2 * PP 
//   * VARGT = ODI * POI * NP * NW * VARi 
// 
//   * OD2    = OD18 
//   * BJTDMY = BJTDMYi 
//   * RPDMYi = RPDMYai 
//   * RPDMY1 = RPDMYa1 
//   * VAR    = VARi 
//   * DIODMY = DIODMYi 
//   * RH_TN = RH_TNi + RH_TNi_S 
//   * CTMDMYt  = CTMDMY9 + CTMDMY8 
//   * SRAM device must have OD_DA(6;15) 
//   * M2i = M2i_ori + M2i_Xd 
//   * M3i = M3i_ori + M3i_Xd 
//   * M4i = M4i_ori + M4i_Xd 
//   * M5i = M5i_ori + M5i_Xd 
//   * M6i = M6i_ori + M6i_Xd 
//   * M7i = M7i_ori + M7i_Xd 
//   * M8i = M8i_ori + M8i_Xd 
//   * M9i = M9i_ori + M9i_Xd 
// 
// 
//////////////////////////////////////////////////////////////////////////////// 
// 
// USER NOTES :  
//  
// 1) Must execute LVS_install.pl to get correct LVS decks . 
// 
// 2) For Calibre "EDTEXT" file, use .INCLUDE strings.txt.  
//        LAYOUT TEXT  "text string" [x] [y]  (layer num) (cell name)  
//  
// 3) Input layer 'OD' is defined as thin oxide (OD) area which would   
//    be drawn by one generic od mask or by seperated N+OD and P+OD.   
//    Remove layers in the 'OD' entries you don't want to use at   
//    layer definition block.  
//  
// 4) Default setting for property check is 0%. Users should check with  
//    IP/Designe providers for proper tolerance.  
//  
// 5) It's recommended to run Calibre LVS by hierarchical mode since false  
//    errors have been encountered by only flat mode option '-lvs'.  
//  
// 6) Default property resolution for ambiguity is set to 32. It could be  
//    necessary to increase this setting to resolve serious ambiguity.  
//    Uncomment statement 'LVS PROPERTY RESOLUTION MAXIMUM' in this deck  
//    to reset the capability of property resolution.  
//  
// 7) Thin oxide layers PDIFF (7;0) and NDIFF (8;0) are not recommended to be  
//    used as tape out layers. Please use OD (6:0) for thin oxide tape out layers.  
//    If PDIFF (7;0) and NDIFF (8;0) layers are used, be sure to check MT (tape out)  
//    form for correctness after modifying this LVS deck (to pass LVS check)  
//  
// 8) By default, the two diodes, pwdnw and dnwpsub, are not extracted in this command   
//     file.  Please turn on the switches, "#DEFINE extract_dnwpsub" and  
//     "#DEFINE extract_pwdnw" to apply the extraction of these two diode.  
// 
// 9) By default, the nw-psub parasitic diode is not extracted. Please turn on the switch 
//     "#DEFINE extract_pnwdio" to apply the extraction of this diode. 
// 
// 10) Layer number 2000 - 2050 is saved for pseudo layer purpose.  
//     Please don't adopt these layers. 
// 
// 11) By default, VIRTUAL CONNECT COLON is set yes. Please set to "NO" as doing full-chip checking. 
// 
// 12) change default setting of option "LVS INJECT LOGIC NO". 
//     Set for "NO" to align the default setting of Calibre version before 2008 to do backward compatible. 
// 
// 13) This file usually reads all datatypes (0-255) for each CAD layer defined.  
//     User customization datatype maybe already included in the layout mapping of this deck.  
//     PLEASE ALWAYS REVIEW THE LAYER DEFINITION AND MODIFY IT FOR USERS' PARTICULAR LAYER USAGE.      
//lvs_gen.pl version: 1.517
//calibre_ff.pl version: 1.632

// LVS/RC_DFM switch option
// --------------------
#define DFM_RULE    //comment this line when this deck would like to exclude DFM rules
//#define RC_DECK    //uncomment this line when this deck would be used as a RC command file
//#define SKIP_ODSE  //uncomment this line to skip od_space_effect
//#define SKIP_MBE   //uncomment this line to skip metal boundary effect
//#define FILTER_DGS_TIED_MOS // uncomment this line to filter MOS with D, G and S tied together (default filter MOS with all pins tied)
#define WELL_TO_PG_CHECK 
// Default is on. Turn on to highlight if nwell connects to ground or psub connects to power.
//#define GATE_TO_PG_CHECK 
// Default is off. Turn on to highlight if a mos gate directly connects to power or ground.
//#define PATH_CHECK 
// Default is off. Turn on to highlight if
//(1) nodes have a path to power but no path to ground
//(2) nodes have a path to ground but no path to power
//(3) nodes have no path to power or ground
//(4) nodes have no path to any label net
#define DS_TO_PG_CHECK 
// Default is on. Turn on to highlight if drain connects to power and source connects to ground.
#define FLOATING_WELL_CHECK 
// Default is on. Turn on to highlight if well does not connect to power or ground. 
//The nwell of moscaps and nwell-resistor are excluded.
#define LVSDMY4_CHECK   
// Default is on. Turn on to highlight if LVSDMY4 without DNW region interact NMOS.

VARIABLE WPED 5
VARIABLE PRESCALE 1.0

//#define NW_RING	//uncomment this line to enable the NW ring to separate the node from BULK

// POWER and GROUND name string variable setting
