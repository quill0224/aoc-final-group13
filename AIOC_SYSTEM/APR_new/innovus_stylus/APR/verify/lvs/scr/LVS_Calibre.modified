   W = (perimeter_coincide(pgate_mpode_mac, tpdiff ) + perimeter_inside(pgate_mpode_mac, tpdiff)) / 2
   L = area(pgate_mpode_mac) / W
   #IFDEF MATCHFLAG
      len_aux = perimeter(matching_aux)/2 - MINGRID_RECT1_UNIT
      matchingflag = 0.0
