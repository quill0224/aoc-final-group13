pch_ulvt_mac_ODN_layer = DEVICE LAYER MP(pch_ulvt_mac) ANNOTATE OD_p
       [PROPERTY ODN, pname
       ODN = DFM_NUM_VAL( OD_p, ODNET)
       pname = "pch_ulvt_mac"
       ]
LVS ANNOTATE DEVICES pch_ulvt_mac_ODN_layer
#ENDIF

