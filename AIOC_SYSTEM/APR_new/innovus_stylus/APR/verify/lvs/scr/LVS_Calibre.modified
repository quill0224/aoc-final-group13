DEVICE MN(nch_svt_dnw_mac) nrgate_mac nrgate_mac(G) tndiff(S) tndiff(D) psub(B) <nthin> <OD> <lod_PROP> <nCore_WPEPROP> <ngate_PROP>  <gate_COR>  <ngate_mbe>  <matching_aux>  <ppitch_aux>  <cpo_aux> netlist model nch_svt_mac netlist element "X" [
   property sa,sb,sca,scb,scc,L,AS,AD,PD,PS,NRD,NRS,nfin,sa1,sb1,sa2,sb2,sa3,sb3,ppitch,dfm_flag
   #IFDEF EXTRACT_W
   ,W
   #ENDIF
   #IFNDEF SKIP_PLE
   ,ploda1,ploda2,ploda3,plodb1,plodb2,plodb3
   #ENDIF
   #IFNDEF SKIP_ODSE
   ,sodxa,sodxb,sodxa1,sodxb1,sodxa2,sodxb2,sodxa4,sodxb4,sa5,sb5,sa6,sb6,sa7,sb7,sodyt,sodyb
   #ENDIF
   #IFNDEF SKIP_MBE
