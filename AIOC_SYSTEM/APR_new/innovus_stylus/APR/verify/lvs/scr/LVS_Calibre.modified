// Serve X-resistor as an built-in resistor (for PATHCHK)
LVS DEVICE TYPE RESISTOR rhim rhim_m rhimw rhimw_m rm1w rm2w rm3w rm4w rm5w rm6w rm7w rm8w rm9w rmap rnwsti rnwsti_m [POS=PLUS NEG=MINUS]
LVS DEVICE TYPE RESISTOR rhim_rf [POS=HI NEG=LO]
LVS DEVICE TYPE RESISTOR rhim_rf_110g [POS=HI NEG=LO]
LVS DEVICE TYPE RESISTOR rhimw_rf [POS=HI NEG=LO]
LVS DEVICE TYPE RESISTOR rhimw_rf_110g [POS=HI NEG=LO]
LVS REDUCE rhim_rf PARALLEL NO
LVS REDUCE rhim_rf SERIES HI LO NO
LVS REDUCE rhim_rf_110g PARALLEL NO
LVS REDUCE rhim_rf_110g SERIES HI LO NO
LVS REDUCE rhimw_rf PARALLEL NO
LVS REDUCE rhimw_rf SERIES HI LO NO
LVS REDUCE rhimw_rf_110g PARALLEL NO
LVS REDUCE rhimw_rf_110g SERIES HI LO NO

