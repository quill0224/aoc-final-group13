trwell_tmp04 = trwell_tmp03 NOT PO
trwell_tmp05 = trwell_tmp04 NOT VTLN_N
trwell_tmp06 = trwell_tmp05 NOT VTLN_P
trwell_tmp07 = trwell_tmp06 NOT PP
trwell_tmp08 = trwell_tmp07 NOT RH_TNi
trwell_tmp09 = trwell_tmp08 NOT RPDMY
trwell_tmp10 = trwell_tmp09 NOT VAR
trwell_tmp11 = trwell_tmp10 NOT BJTDMYi
trwell_tmp12 = trwell_tmp11 NOT IBJTDMY
trwell_tmp13 = trwell_tmp12 NOT DIODMY
trwell_tmp14 = trwell_tmp13 NOT SR_ESD
trwell_tmp15 = trwell_tmp14 NOT SDI
trwell_tmp16 = trwell_tmp15 NOT GATED
trwell_tmp17 = trwell_tmp16 NOT HIA_DUMMY
trwell_tmp18 = trwell_tmp17 NOT SDI_2
trwell_tmp19 = trwell_tmp18 NOT SDI_FOD
trwell_tmp20 = trwell_tmp19 NOT SCR_DMY
trwell_tmp21 = trwell_tmp20 NOT HVD
trwell_tmp22 = trwell_tmp21 NOT HVD_N
trwell_tmp23 = trwell_tmp22 NOT HVD_P
trwell_tmp24 = trwell_tmp23 NOT LRG
trwell_tmp25 = trwell_tmp24 NOT LRG2
trwell_tmp26 = trwell_tmp25 NOT PO_P130
trwell_tmp27 = trwell_tmp26 NOT PO_P130_TP
trwell = trwell_tmp27 NOT RH_TNi_S

nwsti = NW NOT ODI 
nwsti_r1 = trwell INTERACT nwsti  //  NWDMY*NW interact NW wo ODI above
nwsti_r_1 = nwsti_r1 INTERACT NWDMYi 
nwsti_r = nwsti_r_1 NOT HVD_33  //  NW resistor (2T)

