d_tndiff_hv_1 = nthin1_hv_d INTERACT ngate_hv18_mac 
d_tndiff_hv = d_tndiff_hv_1 NOT ngate_hv18_mac 
plug_sel1b = d_tndiff_hv OR d_tpdiff_hv 
plug_sel1 = plug_sel1a OR plug_sel1b 
plug_sel2a = plug_sel1 OR tiod 
plug_sel2a_dummy1 = plug_sel2a NOT INTERACT MD_valid 
plug_sel2a_dummy = plug_sel2a_dummy1 INTERACT psubband 
plug_sel2b = plug_sel2a NOT plug_sel2a_dummy 
DummyOD = DOD OR SR_DOD 
plug_sel2c = DummyOD INTERACT psubband 
plug_sel2 = plug_sel2b NOT INTERACT plug_sel2c 
plug_valid = M0_OD INTERACT MD_valid 
plug_sel3 = plug_sel2a INTERACT plug_valid 
