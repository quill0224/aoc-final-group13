DEVICE cfmom_wo_p80 fmom3_reg_pw_p80_dm M3(PLUS) M3(MINUS) psub(BULK) <MOM_field3> <mom3_extc>   <dmetal1> <dmetal2> <MOMDMY_VAP> <MOMDMY_MXA> <MOMDMY_MXD> <MOM_LAYER_8> <SHIELD_LAYER> <MOM_hole3> <grflag_aux> <mom_SOB> (PLUS MINUS) [
