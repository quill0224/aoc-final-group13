	,spotl2,spotl1,spot,spotr1,spotr2,spobl2,spobl1,spob,spobr1,spobr2
#ENDIF
   dfm_flag = 1
   LR_EXT = MOS_LR_EXT
   TOP_EXT = PMOS_TOP_EXT
   BOT_EXT = 0
   SCALE = PRESCALE
   W = (perimeter_coincide(pch_mpodehvt_mac_gate, tpdiff ) + perimeter_inside(pch_mpodehvt_mac_gate, tpdiff)) / 2
   L = area(pch_mpodehvt_mac_gate) / W
   #IFDEF MATCHFLAG
      len_aux = perimeter(matching_aux)/2 - MINGRID_RECT1_UNIT
      matchingflag = 0.0
      edgeflag = 0.0
      if(len_aux > MINGRID_RECT1_01_UNIT) {
         edgeflag1 = (len_aux/MINGRID_RECT1_UNIT)/2-1
