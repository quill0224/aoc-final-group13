unrecognized_dio_2 = unrecognized_dio_1 OR nmbscr_mac_reg 
unrecognized_dio_n = tndiff_all INTERACT unrecognized_dio_2 
unrecognized_ndio_3 = unrecognized_ndio_2 NOT unrecognized_dio_n 
