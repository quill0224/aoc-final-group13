//* Define device -- xdev ndio_hia18_mac
hia_dio_ngate = tngate0 AND HIA_DUMMY 

//* Define device -- xdev pdio_hia18_mac
hia_dio_pgate = tpgate0 AND HIA_DUMMY 

//* Define device -- xdev ndio_gated18_mac
gate_gdio = gate_gd AND OD18 
ngate_gdio = gate_gdio NOT NW 

//* Define device -- xdev pdio_gated18_mac
mdiff_gdio1 = mdiff AND GATED 
mdiff_gdio = mdiff_gdio1 AND OD18 
npdiff_gdio1 = mdiff_gdio NOT gate 
npdiff_gdio = npdiff_gdio1 INTERACT gate_gdio 
ndiff_gdio = mdiff_gdio INTERACT ngate_gdio  //  1.8v Gated N-type diode active
pgate_gdio = gate_gdio AND NW 
pgate_gdio_2t = COPY pgate_gdio 
pdiff_gdio = mdiff_gdio INTERACT pgate_gdio_2t  //  1.8v Gated P-type diode active

//* Define device -- xdev ndio_hia18_mac_rf
gate_rf_AND_HIA = gate_rf AND HIA_DUMMY 
gatennw_rf = gate_rf_AND_HIA NOT nxwell 
hia_dio_ngate_rf = gatennw_rf AND NP 
mdiff_hiadio1 = mdiff AND HIA_DUMMY 
mdiff_hiadio = mdiff_hiadio1 AND OD18 
ndiff_hiadio_rf = mdiff_hiadio INTERACT hia_dio_ngate_rf 

//***** Define connectivity/via layer -- RFDMY_HIA_bulk ****
nxwell_AND_RFDMY = nxwell AND RFDMY 
RFDMY_HIA_bulk1 = nxwell_AND_RFDMY INTERACT HIA_DUMMY 
RFDMY_HIA_bulk = SIZE RFDMY_HIA_bulk1 BY 0.005 

//* Define device -- xdev pdio_hia18_mac_rf
gatenw_rf = gate_rf_AND_HIA AND nxwell 
hia_dio_pgate_rf = gatenw_rf AND PP 
pdiff_hiadio_rf = mdiff_hiadio INTERACT hia_dio_pgate_rf 

//* Define device -- xdev ndio_gated18_mac_rf
gate_gdio_rf = gate_gd_rf AND OD18 
ngate_gdio_rf = gate_gdio_rf NOT NW 

//* Define device -- xdev pdio_gated18_mac_rf
npdiff_gdio1_rf = mdiff_gdio NOT gate_rf 
npdiff_gdio_rf = npdiff_gdio1_rf INTERACT gate_gdio_rf 
ndiff_gdio_rf = mdiff_gdio INTERACT ngate_gdio_rf  //  RF 1.8v Gated N-type diode active

//***** Define connectivity/via layer -- RFDMY_GATED_bulk ****
RFDMY_GATED_bulk1 = nxwell_AND_RFDMY INTERACT GATED 
RFDMY_GATED_bulk = SIZE RFDMY_GATED_bulk1 BY 0.005 
pgate_gdio_rf = gate_gdio_rf AND NW 
pgate_gdio_rf_3t = pgate_gdio_rf AND RFDMY 
pdiff_gdio_rf = mdiff_gdio INTERACT pgate_gdio_rf_3t 

//* Define device -- xdev nfod_npwnw_mac
sdi_fod_ngate = gatenw AND NP 
nthin_nw = nthin INTERACT nxwell 
tndiff_dio_sdi2 = tndiff_dio AND SDI_2 

//* Define device -- xdev nmbscr_mac
nmbscr_mac_reg1 = SCRu_DMY INTERACT ngate_mbscr 
nmbscr_mac_reg_1 = nmbscr_mac_reg1 INTERACT PP 
nmbscr_mac_reg = nmbscr_mac_reg_1 NOT HVD_33  //   1.8v N-type MBSCR

//* Define device -- xdev pmbscr_mac
gate_mbscr = ngate_mbscr OR pgate_mbscr 
npdiff_mbscr = npdiff_gdio1 INTERACT gate_mbscr 
ndiff_mbscr = mdiff_gdio INTERACT ngate_mbscr  //   1.8v MBSCR N-type active
pmbscr_mac_reg1 = SCRd_DMY INTERACT pgate_mbscr 
pmbscr_mac_reg_1 = pmbscr_mac_reg1 INTERACT NP 
pmbscr_mac_reg = pmbscr_mac_reg_1 NOT HVD_33  //   1.8v P-type MBSCR
pdiff_mbscr = mdiff_gdio INTERACT pgate_mbscr  //   1.8v MBSCR P-type active

//* Define device -- xdev dnwpsub
dnwdio_b = nxwell INTERACT DNW 
dnwdio_a = nxwell INSIDE DNW 
poly_rf0 = PO AND RFDMY 
poly_rf1 = poly_rf0 INTERACT M0_PO 
poly_rf = poly_rf1 INTERACT DRAIN 
gate_rfb = gate_rf AND poly_rf 
gate_rfc = gate_rfb NOT VAR 
gate_rfnnw = gate_rfc NOT nxwell  //  gate_rf not inside nwell
ngate_rf1 = gate_rfnnw AND NP 
nmos_rf5t = RFDMY5T INTERACT ngate_rf1 
dnwdio_c = dnwdio_a NOT nmos_rf5t 
dnwdio_k = dnwdio_b NOT dnwdio_c 
dnwdio1 = DNW INTERACT dnwdio_k 
gate_rfnw = gate_rfc AND nxwell  //  gate_rf inside nwell
pgate_rf1 = gate_rfnw AND PP 
pmos_rf5t = RFDMY5T INTERACT pgate_rf1 
dnwdio2a = dnwdio1 NOT pmos_rf5t 
dnwdio2 = dnwdio2a NOT RFDMY6T 
dnwdio_rf_var1 = dnwdio1 AND RFDMY 
dnwdio_rf_var = dnwdio_rf_var1 INTERACT VAR 
dnwdio3 = dnwdio2 NOT dnwdio_rf_var 
dnwdio = COPY dnwdio3 

//* Define device -- xdev pwdnw
rwdio1 = DNW NOT nxwell 
rwdio2a = rwdio1 NOT BJTDMY 
rwdio2 = rwdio2a NOT HVD_P 
rfdmy5T6T = RFDMY5T OR RFDMY6T 
rwdio3 = rwdio2 NOT rfdmy5T6T 
rwdio_rf_var1 = rwdio2 AND RFDMY 
rwdio_rf_var = rwdio_rf_var1 INTERACT VAR 
rwdio4 = rwdio3 NOT rwdio_rf_var 
rwdio = COPY rwdio4 

//***** Define connectivity/via layer -- psub_term ****
psub_term_a = psub2s NOT PSUB2 
psub_term_b = BULK NOT psub_term_a 
psub_term_c = BULK AND DNW 
psub_term_d = BULK NOT psub_term_c 
psub_term_e = psub_term_b AND psub_term_d 
psub_term = psub_term_e INTERACT DNW 

//* Define device -- xdev pnwdio
pnwdio1 = nxwell OUTSIDE nwdio_r 
pnwdio2a = pnwdio1 NOT DNW 
pnwdio2b = pnwdio2a NOT BJTDMY1 
pnwdio2 = pnwdio2b NOT HVD_N 
rwel = psub INSIDE DNW 
pnwdio3 = pnwdio1 INSIDE rwel 
pnwdio4 = pnwdio2 OR pnwdio3 
pnwdio_rf_var1 = pnwdio4 AND RFDMY 
pnwdio_rf_var = pnwdio_rf_var1 INTERACT VAR 
pnwdio4a = pnwdio4 NOT pnwdio_rf_var 
pnwdio4b = pnwdio4a NOT SDI_FOD 
pnwdio_rf_dio1 = pnwdio4 INTERACT pgdio_rf 
pnwdio_rf_dio2 = pnwdio4 INTERACT hia_pdio_r_rf 
pnwdio_rf_dio = pnwdio_rf_dio1 OR pnwdio_rf_dio2 
pnwdio5 = pnwdio4b NOT pnwdio_rf_dio 
pnwdio6a = pnwdio5 NOT pmos_rf5t 
pnwdio6 = pnwdio6a NOT RFDMY6T 
pnwdio_r = pnwdio6 TOUCH psub == 1

