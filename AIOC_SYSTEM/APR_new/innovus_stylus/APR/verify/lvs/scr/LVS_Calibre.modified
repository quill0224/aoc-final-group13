LAYOUT CELL LIST pcells "cfmom_2t_p80*" "cfmom_2t_p80_odd*" "cfmom_mx_4t_p80*" "cfmom_wo_mx_p80*" "cfmom_wo_p80*" "cfmom_wo_p80_odd*" "cfmom_wo_p80_rf*" "cfmom_wo_p80_rf_110g*" "cfmom_wo_p80_rf_odd*" "cfmom_wo_p80_rf_odd_110g*" "crtmom_2t*" "crtmom_mx_4t*" "crtmom_wo*" "crtmom_wo_mx*" "crtmom_wo_rf*" "csfmom_2t*" "moscap_rf*" "moscap_rf18*" "moscap_rf18_110g*" "moscap_rf18_nw*" "moscap_rf18_nw_110g*" "moscap_rf_110g*" "moscap_rf_nw*" "moscap_rf_nw_110g*" "ndio_gated18_mac_rf*" "ndio_hia18_mac_rf*" "nmbscr_mac*" "nmos_rf_18_5t*" "nmos_rf_18_6t*" "nmos_rf_18_nw*" "mod_nmos_rf_18_nw*" "nmos_rf_18ud12_5t*" "nmos_rf_18ud12_6t*" "nmos_rf_18ud12_nw*" "mod_nmos_rf_18ud12_nw*" "nmos_rf_18ud15_5t*" "nmos_rf_18ud15_6t*" "nmos_rf_18ud15_nw*" "mod_nmos_rf_18ud15_nw*" "nmos_rf_lvt_5t*" "nmos_rf_lvt_6t*" "nmos_rf_lvt_nw*" "mod_nmos_rf_lvt_nw*" "nmos_rf_svt_5t*" "nmos_rf_svt_6t*" "nmos_rf_svt_nw*" "mod_nmos_rf_svt_nw*" "nmos_rf_ulvt_5t*" "nmos_rf_ulvt_5t_110g*" "nmos_rf_ulvt_5t_pp*" "nmos_rf_ulvt_5t_pp_110g*" "nmos_rf_ulvt_6t*" "nmos_rf_ulvt_6t_110g*" "nmos_rf_ulvt_6t_pp*" "nmos_rf_ulvt_6t_pp_110g*" "nmos_rf_ulvt_6t_pp_asw_110g*" "nmos_rf_ulvt_nw*" "mod_nmos_rf_ulvt_nw*" "nmos_rf_ulvt_nw_110g*" "nmos_rf_ulvt_nw_pp*" "nmos_rf_ulvt_nw_pp_110g*" "nmosgr_rf*" "pdio_gated18_mac_rf*" "pdio_hia18_mac_rf*" "pmbscr_mac*" "pmos_rf_18_5t*" "pmos_rf_18_nw*" "mod_pmos_rf_18_nw*" "pmos_rf_18ud12_5t*" "pmos_rf_18ud12_nw*" "mod_pmos_rf_18ud12_nw*" "pmos_rf_18ud15_5t*" "pmos_rf_18ud15_nw*" "mod_pmos_rf_18ud15_nw*" "pmos_rf_lvt_5t*" "pmos_rf_lvt_5t_pp_hfmax*" "pmos_rf_lvt_5t_pp_hfmax_110g*" "pmos_rf_lvt_nw*" "mod_pmos_rf_lvt_nw*" "pmos_rf_lvt_nw_pp_hfmax*" "pmos_rf_lvt_nw_pp_hfmax_110g*" "pmos_rf_svt_5t*" "pmos_rf_svt_nw*" "mod_pmos_rf_svt_nw*" "pmos_rf_ulvt_5t*" "pmos_rf_ulvt_nw*" "mod_pmos_rf_ulvt_nw*" "pmosgr_rf*" "rhim_rf*" "rhim_rf_110g*" "rhimw_rf*" "rhimw_rf_110g*" "spiral_std_mu_z_dm*" "spiral_sym_ct_mu_z_a28_dm*" "spiral_sym_mu_z_dm*" 
#IFDEF RC_DECK
