P_h_s_edge2 = P_h_s_edge1 INSIDE EDGE Small_Poly3 
P_h_s_edge = P_h_s_edge1 TOUCH EDGE P_h_s_edge2
VTH_P_exp_hs = EXPAND EDGE P_h_s_edge OUTSIDE BY VT_SHIFTED_DISTANCE
VTSP1 = VTS_P NOT VTH_P_exp_hs 
VTL_P_rgn1 = VTL_P OR VTUL_P 
VTL_P_rgn2 = VTL_P_rgn1 OR Empty 
VTL_P_rgn3 = VTL_P_rgn2 OR Empty 
VTL_P_rgn = VTL_P_rgn3 OR VTLN_P 
P_s_l_edge1 = VTS_P COINCIDENT EDGE VTL_P_rgn
P_s_l_edge2 = P_s_l_edge1 INSIDE EDGE Small_Poly3 
P_s_l_edge = P_s_l_edge1 TOUCH EDGE P_s_l_edge2
VTS_P_exp = EXPAND EDGE P_s_l_edge OUTSIDE BY VT_SHIFTED_DISTANCE
VTSP = VTSP1 OR VTS_P_exp 
p_gpoly_svt_rf = p_gpoly_rf AND VTSP 

