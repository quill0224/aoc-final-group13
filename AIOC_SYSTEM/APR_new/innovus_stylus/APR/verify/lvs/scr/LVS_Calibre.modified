ppoly_co_s2 = ppoly_co_s1 OR VAR_and_PP 
ppoly_co_s3 = ppoly_co_s2 NOT OD2 
ppoly_co_s = poly1 AND ppoly_co_s3 
p_fpoly_svt = ppoly_co_s NOT OD 

//***** Define connectivity/via layer -- p_gptap_lvtlr ****
poly_mp_tap_ori = M0_PO AND poly_org 
poly_mp_tap = poly_mp_tap_ori NOT poly_rf 
gptap = poly_mp_tap AND OD 
npoly_co_l1 = VTLN NOT sram_np 
BJTDMYi_and_NP = BJTDMYi AND NP 
npoly_co_l2 = npoly_co_l1 OR BJTDMYi_and_NP 
DIODMYi_and_NP = DIODMYi AND NP 
npoly_co_l3 = npoly_co_l2 OR DIODMYi_and_NP 
npoly_co_l4 = npoly_co_l3 NOT OD2 
npoly_co_l = poly1 AND npoly_co_l4 
poly_set1 = npoly_co_s OR npoly_co_l 
poly_set2 = poly_set1 OR ppoly_co_s 
poly_set3 = poly_set2 OR npoly_io 
ppoly_io = poly_io NOT npoly_io 
poly_set4 = poly_set3 OR ppoly_io 
npoly_co_srm = poly1 AND sram_n 
poly_set5 = poly_set4 OR npoly_co_srm 
ppoly_co_srm = poly1 AND sram_p 
poly_set6 = poly_set5 OR ppoly_co_srm 
VTHP1 = VTH_P OR VTH_P_exp_hs 
VTHP = VTHP1 OR VTH_P_exp_hl 
ppoly_co_h1 = VTHP NOT sram_np 
ppoly_co_h2 = ppoly_co_h1 NOT OD2 
ppoly_co_h = poly1 AND ppoly_co_h2 
poly_set7 = npoly_co_h OR ppoly_co_h 
poly_set = poly_set6 OR poly_set7 
ppoly_co_l = poly1 NOT poly_set 
p_fpoly_lvt1 = ppoly_co_l NOT OD 
p_gpoly_lvt_all1 = ppoly_co_l NOT p_fpoly_lvt1 
p_gpoly_lvtlr_all = p_gpoly_lvt_all1 AND LRG 
p_gptap_lvtlr = gptap AND p_gpoly_lvtlr_all 

//***** Define connectivity/via layer -- mom8p2 ****
mom8p21 = M8 AND MOMDMY24 
mom8p2 = mom8p21 INTERACT MOMDMY25 

//***** Define connectivity/via layer -- p_fptap_cpode ****
fptap_com_cpode = M0_PO AND poly_cpode 
n_cpode = poly_cpode AND NP 
p_cpode = poly_cpode NOT n_cpode 
p_fptap_cpode = fptap_com_cpode INTERACT p_cpode 

