n_gpoly_svt_all = npoly_co_s NOT n_fpoly_svt 
n_gpoly_svt = n_gpoly_svt_all NOT all_mos_gates 

//* Define device -- xdev moscap_rf_110g
vargt_rfa = gate_rf AND VAR_RF 
vargt_rf1 = vargt_rfa NOT VAR10 
vargt_rf2 = vargt_rf1 NOT VAR11 
vargt_rf3 = vargt_rf2 NOT OD2 
vargt_rf = vargt_rf3 NOT VTH_P  //  RF Varactor on thin oxide
vargt_rf_aux = COPY vargt_rf  //  aux layer for RF Varactor

//* Define device -- xdev moscap_rf18_nw
var_nw_rf18a = var_nw_rf AND OD18 
