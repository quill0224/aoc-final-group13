rhim_r = rhim_r_1 NOT HVD_33  //  2T TiN resistor

//* Define device -- xdev rhim_m
RPDMY1_noRF = RPDMY1 NOT INTERACT RFDMY 
rhim_d = rhim1 INTERACT RPDMY1_noRF  //  3T TiN resistor

//***** Define connectivity/via layer -- RH_TN_term ****
RH_TNi_all = RH_TNi OR RH_TNi_S 
RH_TN_term1 = RH_TNi_all AND RPDMY1 
RH_TN_term2 = SIZE RH_TN_term1 BY 0.005 
RH_TN_term = RH_TN_term2 NOT RH_TN_term1 

//* Define device -- xdev rhimw
rhimw1_a = rhimw1 NOT RFDMY 
rhimw_r_1 = rhimw1_a INTERACT RPDMYi 
rhimw_r = rhimw_r_1 NOT HVD_33  //  2T TiN resistor

//* Define device -- xdev rhimw_m
rhimw_d = rhimw1_a INTERACT RPDMY1  //  3T TiN resistor

//* Define device -- xdev rhim_rf
rhim_rf_r1 = rhim1 AND RFDMY 
