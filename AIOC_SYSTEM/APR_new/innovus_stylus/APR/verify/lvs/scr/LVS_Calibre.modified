//# LOGIC OPERATION POOL                      #
//#############################################

//Form BULK layer
DRC:1 = EXTENT
BULK  = SIZE DRC:1 BY 0.005

//***** Define connectivity/via layer -- ngate_mac ****

//* Define layer -- ngate_mac
ngate_mac_tmp01 = tngate3 NOT dnwdmy
ngate_mac_tmp02 = ngate_mac_tmp01 NOT OD18
ngate_mac_tmp03 = ngate_mac_tmp02 NOT NT_N
ngate_mac_tmp04 = ngate_mac_tmp03 NOT VTLN_N
ngate_mac_tmp05 = ngate_mac_tmp04 NOT VTLN_P
ngate_mac_tmp06 = ngate_mac_tmp05 NOT VTUL_N
ngate_mac_tmp07 = ngate_mac_tmp06 NOT VTUL_P
ngate_mac_tmp08 = ngate_mac_tmp07 NOT VTIL_N
ngate_mac_tmp09 = ngate_mac_tmp08 NOT VTIL_P
ngate_mac_tmp10 = ngate_mac_tmp09 NOT VTL_N
ngate_mac_tmp11 = ngate_mac_tmp10 NOT VTL_P
ngate_mac_tmp12 = ngate_mac_tmp11 AND VTS_N
ngate_mac_tmp13 = ngate_mac_tmp12 NOT VTS_P
ngate_mac_tmp14 = ngate_mac_tmp13 NOT VTH_N
ngate_mac_tmp15 = ngate_mac_tmp14 NOT VTH_P
ngate_mac_tmp16 = ngate_mac_tmp15 NOT OD18_12
ngate_mac_tmp17 = ngate_mac_tmp16 NOT OD18_15
ngate_mac_tmp18 = ngate_mac_tmp17 NOT SR_ESD
ngate_mac_tmp19 = ngate_mac_tmp18 NOT SDI_2
ngate_mac_tmp20 = ngate_mac_tmp19 NOT SDI_FOD
ngate_mac_tmp21 = ngate_mac_tmp20 NOT HVD
ngate_mac_tmp22 = ngate_mac_tmp21 NOT HVD_N
ngate_mac_tmp23 = ngate_mac_tmp22 NOT HVD_P
ngate_mac_tmp24 = ngate_mac_tmp23 NOT LRG
ngate_mac_tmp25 = ngate_mac_tmp24 NOT LRG2
ngate_mac_tmp26 = ngate_mac_tmp25 NOT PO_P130
ngate_mac_tmp27 = ngate_mac_tmp26 NOT PO_P130_TP
ngate_mac_tmp28 = ngate_mac_tmp27 NOT RH_TNi_S
ngate_mac = ngate_mac_tmp28 NOT HVD_33


//***** Define connectivity/via layer -- psub ****
ppsub_1 = BULK NOT NW 
ppsub_2 = ppsub_1 NOT HVD_N 
ppsub = ppsub_2 OR HVD_P  //   define total p_sub region
psub2s = SIZE PSUB2 BY 0.01 
psubband = psub2s NOT PSUB2  //   psub separator band (doughnut).
psub = ppsub NOT psubband 

//***** Define connectivity/via layer -- nlvgate_mac ****

//* Define layer -- nlvgate_mac
nlvgate_mac_tmp01 = tngate3 NOT dnwdmy
nlvgate_mac_tmp02 = nlvgate_mac_tmp01 NOT OD18
nlvgate_mac_tmp03 = nlvgate_mac_tmp02 NOT NT_N
nlvgate_mac_tmp04 = nlvgate_mac_tmp03 NOT VTLN_N
nlvgate_mac_tmp05 = nlvgate_mac_tmp04 NOT VTLN_P
nlvgate_mac_tmp06 = nlvgate_mac_tmp05 NOT VTUL_N
nlvgate_mac_tmp07 = nlvgate_mac_tmp06 NOT VTUL_P
nlvgate_mac_tmp08 = nlvgate_mac_tmp07 NOT VTIL_N
nlvgate_mac_tmp09 = nlvgate_mac_tmp08 NOT VTIL_P
nlvgate_mac_tmp10 = nlvgate_mac_tmp09 AND VTL_N
nlvgate_mac_tmp11 = nlvgate_mac_tmp10 NOT VTL_P
nlvgate_mac_tmp12 = nlvgate_mac_tmp11 NOT VTS_N
nlvgate_mac_tmp13 = nlvgate_mac_tmp12 NOT VTS_P
nlvgate_mac_tmp14 = nlvgate_mac_tmp13 NOT VTH_N
nlvgate_mac_tmp15 = nlvgate_mac_tmp14 NOT VTH_P
nlvgate_mac_tmp16 = nlvgate_mac_tmp15 NOT OD18_12
nlvgate_mac_tmp17 = nlvgate_mac_tmp16 NOT OD18_15
