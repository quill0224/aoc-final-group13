npoly_co_h = poly1 AND npoly_co_h2 
n_fpoly_hvt = npoly_co_h NOT OD 
n_gpoly_hvt_all = npoly_co_h NOT n_fpoly_hvt 
n_gpoly_hvt = n_gpoly_hvt_all NOT all_mos_gates 

//***** Define connectivity/via layer -- p_fpoly_svt ****
ppoly_co_s1 = VTSP NOT sram_np 
