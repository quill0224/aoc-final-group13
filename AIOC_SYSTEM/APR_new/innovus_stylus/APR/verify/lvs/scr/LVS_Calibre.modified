DEVICE spiral_std_mu_z_dm std_mu_z_dm_ind indm9p(TOP) indm9m(BOTTOM) psub(GNODE) <IND_RAD> <IND_GDIS> <IND_NR> <IND_W> <IND_S> <IND_LAY_MX_MXA> <IND_LAY_MY> netlist model spiral_std_mu_z_dm [
   PROPERTY nr,rad,w,spacing,gdis,lay,lay_xa,lay_y
   lay     = 9
   nnr     = ( perimeter(IND_NR) - 5e-9*2 ) / 2
   nr      = ( nnr / 1e-8 ) * 0.25
   rad     = ( perimeter(IND_RAD) - 5e-7*2 ) / 2
   gdis    = ( perimeter(IND_GDIS) - 5e-7*2 ) / 2
   w       = ( perimeter(IND_W) - 5e-7*2 ) / 2
   spacing = ( perimeter(IND_S) - 5e-7*2 ) / 2
   lay_xa  = TRUNC( (( ( perimeter(IND_LAY_MX_MXA) - 5e-7*2 ) / 2 ) * 1e6) + 0.01 )
   lay_y   = TRUNC( (( ( perimeter(IND_LAY_MY)     - 5e-7*2 ) / 2 ) * 1e6) + 0.01 )
]
TRACE PROPERTY spiral_std_mu_z_dm w       w       SPIRAL_Werr
TRACE PROPERTY spiral_std_mu_z_dm spacing spacing SPIRAL_Serr
TRACE PROPERTY spiral_std_mu_z_dm nr      nr      0
TRACE PROPERTY spiral_std_mu_z_dm gdis    gdis    0
TRACE PROPERTY spiral_std_mu_z_dm rad     rad     0
TRACE PROPERTY spiral_std_mu_z_dm lay     lay     0
TRACE PROPERTY spiral_std_mu_z_dm lay_xa  lay_xa  0
TRACE PROPERTY spiral_std_mu_z_dm lay_y   lay_y   0

