       #IFDEF EXTRACT_W
       ,wr
       #ENDIF

       lr = perimeter_coincide(vargt_18,nthin)/2
       wr = area(vargt_18)/lr
       nfin = TRUNC( ((wr * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )
]
