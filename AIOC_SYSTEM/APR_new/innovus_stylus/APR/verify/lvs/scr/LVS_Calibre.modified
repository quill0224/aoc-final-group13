//***** Define connectivity/via layer -- pplug ****
d_tpdiff_hv_1 = pthin1_hv_d INTERACT pgate_hv18_mac 
d_tpdiff_hv = d_tpdiff_hv_1 NOT pgate_hv18_mac 
pplug0 = tpdiff_ori OR d_tpdiff_hv 
pplug1 = pplug0 AND psub 
