rfdio_SOB_base_gated = NW INTERACT GATED 
rfdio_SOB_base_b = EXTENTS gate_rf_AND_NW INSIDE OF LAYER rfdio_SOB_base_gated
rfdio_SOB_base = rfdio_SOB_base_a OR rfdio_SOB_base_b 
