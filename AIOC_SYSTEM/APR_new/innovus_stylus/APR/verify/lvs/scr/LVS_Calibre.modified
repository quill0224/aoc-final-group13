ponw_s = realpo_s AND nxwell 
pponw_s = ponw_s AND PP  //  SRAM PMOS
pgate_s_normal1 = pponw_s AND SRMDEVi 
pgate_s_normal2 = pgate_s_normal1 NOT BSRMDEVi 
