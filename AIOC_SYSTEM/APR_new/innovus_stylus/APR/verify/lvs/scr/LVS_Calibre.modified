//* Define device -- xdev rm2w
M2i = M2i_ori OR M2i_Xd 
metal2i = M2i OR DUM2  // ALL metal pattern
M2Y = metal2i NOT INDDMY 
mt2resa = M2Y AND RMDMY2 
mt2resb = mt2resa NOT INTERACT MFUSE 
mt2resc = mt2resb NOT INTERACT VIAFUSE 
mt2res_ori = mt2resc INTERACT M2i  //  M2 resistor
VIA2 = COPY VIA2i 
mt2res_body_and_via_up = mt2res_ori AND VIA2 
mt2res_1 = mt2res_ori NOT INTERACT mt2res_body_and_via_up 
mt2res_body_and_via_down = mt2res_ori AND VIA1 
mt2res = mt2res_1 NOT INTERACT mt2res_body_and_via_down 

//***** Define connectivity/via layer -- M2 ****
M2Z = M2Y NOT mt2res 
m2efuse1 = M2Y AND MFUSE 
m2efuse2 = m2efuse1 NOT INTERACT RMDMY2 
m2efuse = m2efuse2 NOT INTERACT VIAFUSE 
M2W = M2Z NOT m2efuse 
m2vfuse = M2Y AND VIAFUSE 
M3i = M3i_ori OR M3i_Xd 
metal3i = M3i OR DUM3  // ALL metal pattern
M3Y = metal3i NOT INDDMY 
m3vfuse = M3Y AND VIAFUSE 
v2efuse1 = m2vfuse OR m3vfuse 
v2fuse = VIA2i AND VIAFUSE 
v2efuse2 = v2efuse1 INTERACT v2fuse 
v2efuse3 = v2efuse2 NOT INTERACT MFUSE 
v2efuse4 = v2efuse3 NOT INTERACT RMDMY2 
v2efuse = v2efuse4 NOT INTERACT RMDMY3 
M2 = M2W NOT v2efuse  //  M2 interconnect

//* Define device -- xdev rm3w
mt3resa = M3Y AND RMDMY3 
mt3resb = mt3resa NOT INTERACT MFUSE 
mt3resc = mt3resb NOT INTERACT VIAFUSE 
