mt3res_1 = mt3res_ori NOT INTERACT mt3res_body_and_via_up 
mt3res_body_and_via_down = mt3res_ori AND VIA2 
mt3res = mt3res_1 NOT INTERACT mt3res_body_and_via_down 

//***** Define connectivity/via layer -- M3 ****
M3Z = M3Y NOT mt3res 
M3W = M3Z NOT v2efuse 
M3 = COPY M3W 

