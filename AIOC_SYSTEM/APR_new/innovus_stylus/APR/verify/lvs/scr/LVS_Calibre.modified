rhim_rf_r = rhim_rf_r_all NOT INTERACT RFDMY_mmW  //  RF 3T TiN resistor

//* Define device -- xdev rhimw_rf_110g
rhimw_rf_r1 = rhimw1 AND RFDMY 
rhimw_rf_r2 = rhimw_rf_r1 AND RH_TNB_S 
rhimw_rf_r3 = rhimw_rf_r2 NOT HVD_33 
rhimw_rf_r_all = rhimw_rf_r3 AND nxwell 
rhimw_rhim_rf_r_all = rhim_rf_r_all OR rhimw_rf_r_all 
rhim_rf_not_rotate = rhimw_rhim_rf_r_all NOT RPGRDMY 
rotation_aux00 = RECTANGLES MINGRID_RECT1 MINGRID_RECT1 1000 INSIDE OF LAYER rhim_rf_not_rotate
rhim_rf_and_rotate = rhimw_rhim_rf_r_all AND RPGRDMY 
rotation_aux01 = RECTANGLES MINGRID_RECT1 MINGRID_RECT2 1000 INSIDE OF LAYER rhim_rf_and_rotate
rotation_aux = rotation_aux00 OR rotation_aux01 

//* Define device -- xdev rhimw_rf
rhimw_rf_r = rhimw_rf_r_all NOT INTERACT RFDMY_mmW  //  RF 3T TiN Small width resistor

//* Define device -- xdev rhim_rf_110g
rhim_rf_r_110g = rhim_rf_r_all INTERACT RFDMY_mmW  //  RF(110g) 3T TiN resistor
rhimw_rf_r_110g = rhimw_rf_r_all INTERACT RFDMY_mmW  //  RF(110g) 3T TiN Small width resistor

