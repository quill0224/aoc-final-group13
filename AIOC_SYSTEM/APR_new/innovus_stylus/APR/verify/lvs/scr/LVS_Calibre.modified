//***** Define connectivity/via layer -- p_gptap_svt_rf ****
p_gptap_svt_rf = gptap_com_rf AND p_gpoly_svt_rf 
aux_pgate_pthin_5t = DFM PROPERTY rfdmy5t_odnum pgate_pthin_rf  OVERLAP
		       [ count_num = COUNT(pgate_pthin_rf)]
gate_mac1 = tngate1 OR tpgate1 
gate_mac2 = gate_mac1 NOT PODE_3T  //   for layout effect measurement
gate_mac3 = gate_mac2 TOUCH all_sd == 2
gate_mac4 = gate_mac3 OR ngate_hv18_mac 
gate_mac = gate_mac4 OR pgate_hv18_mac 

//***** Define connectivity/via layer -- n_fptap_io ****
n_fptap_io = fptap AND n_fptap_com_io 

//***** Define connectivity/via layer -- cmom2p ****
cmom2p = cmom2p1 INTERACT MOMDMY201 

//***** Define connectivity/via layer -- mom3m1 ****
mom3m1 = mom3p11 NOT INTERACT MOMDMY25 
pgate_s_bend1 = pponw_s NOT SRMDEVi 
pgate_s_bend2 = pgate_s_bend1 AND BSRMDEVi 
pgate_s_bend = pgate_s_bend2 INTERACT gate1 
rf_mos_body_noFW = rf_mos_body NOT INTERACT RFDMY_FW 
rf_mos_body_noFWCI = rf_mos_body_noFW NOT INTERACT RFDMY_CI 
cbflag_aux00 = RECTANGLES MINGRID_RECT1 MINGRID_RECT1 1000 INSIDE OF LAYER rf_mos_body_noFWCI
rf_mos_body_FW = rf_mos_body INTERACT RFDMY_FW 
cbflag_aux01 = RECTANGLES MINGRID_RECT1 MINGRID_RECT1 1000 INSIDE OF LAYER rf_mos_body_FW
cbflag_aux1 = cbflag_aux00 OR cbflag_aux01 
rf_mos_body_CI = rf_mos_body INTERACT RFDMY_CI 
cbflag_aux10 = RECTANGLES MINGRID_RECT1 MINGRID_RECT2 1000 INSIDE OF LAYER rf_mos_body_CI
cbflag_aux = cbflag_aux1 OR cbflag_aux10 

//***** Define connectivity/via layer -- ptap ****
ptap1 = tpdiff_ori AND psub 
ptap2 = ptap1 OR Empty 
ptap3 = ptap2 AND plug_sel 
ptap = ptap3 NOT TCDOVL 
dnwdmy = DNW AND LVSDMY4 

