DEVICE MN(nch_hftulvt_mac) nhftuvgate_mac nhftuvgate_mac(G) tndiff(S) tndiff(D) psub(B) <nthin> <OD> <lod_PROP> <nCore_WPEPROP> <ngate_PROP>  <gate_COR>  <ngate_mbe>  <matching_aux>  <cpo_aux> netlist model nch_hftulvt_mac netlist element "X" [
   property sa,sb,sca,scb,scc,L,AS,AD,PD,PS,NRD,NRS,nfin,sa1,sb1,sa2,sb2,sa3,sb3,dfm_flag
   #IFDEF EXTRACT_W
   ,W
   #ENDIF
   #IFNDEF SKIP_PLE
   ,ploda1,ploda2,ploda3,plodb1,plodb2,plodb3
   #ENDIF
   #IFNDEF SKIP_ODSE
   ,sodxa,sodxb,sodxa1,sodxb1,sodxa2,sodxb2,sodxa4,sodxb4,sa5,sb5,sa6,sb6,sa7,sb7,sodyt,sodyb
   #ENDIF
   #IFNDEF SKIP_MBE
   ,smbt,smbb
   #ENDIF
   #IFDEF MATCHFLAG
   ,matchingflag, edgeflag
   #ENDIF
#IFNDEF SKIP_CPO
	,spotl2,spotl1,spot,spotr1,spotr2,spobl2,spobl1,spob,spobr1,spobr2
#ENDIF
   dfm_flag = 1
   LR_EXT = MOS_LR_EXT
   TOP_EXT = 0
   BOT_EXT = NMOS_BOT_EXT
   SCALE = PRESCALE
   W = (perimeter_coincide(nhftuvgate_mac, tndiff ) + perimeter_inside(nhftuvgate_mac, tndiff)) / 2
   L = area(nhftuvgate_mac) / W
   #IFDEF MATCHFLAG
      len_aux = perimeter(matching_aux)/2 - MINGRID_RECT1_UNIT
      matchingflag = 0.0
      edgeflag = 0.0
      if(len_aux > MINGRID_RECT1_01_UNIT) {
         edgeflag1 = (len_aux/MINGRID_RECT1_UNIT)/2-1
         if (edgeflag1 > 0.5) {
            edgeflag = 1
         } else {
            edgeflag = 0
         }
         matchingflag = 1
      }
   #ENDIF
#IFNDEF SKIP_CPO
    y_self_b   = DFM_VEC_VAL( cpo_aux, "y_s_b" )
    y_self_t   = DFM_VEC_VAL( cpo_aux, "y_s_t" )
    y_totl_b   = DFM_VEC_VAL( cpo_aux, "y_t_b" )
    y_totl_t   = DFM_VEC_VAL( cpo_aux, "y_t_t" )

    y_totl_fb  = DFM_VEC_VAL( cpo_aux, "y_t_fb")
    y_totl_ft  = DFM_VEC_VAL( cpo_aux, "y_t_ft")

    poend_b = TVF_STR_FUN::parameter_equation::poend_pre( y_self_b, y_totl_b, y_totl_fb )
    poend_t = TVF_STR_FUN::parameter_equation::poend_pre( y_self_t, y_totl_t, y_totl_ft )
    spotl2  = TVF_NUM_FUN::parameter_equation::poend_out( poend_t, 0, UNIT_LENGTH() )
    spotl1  = TVF_NUM_FUN::parameter_equation::poend_out( poend_t, 1, UNIT_LENGTH() )
    spot    = TVF_NUM_FUN::parameter_equation::poend_out( poend_t, 2, UNIT_LENGTH() )
    spotr1  = TVF_NUM_FUN::parameter_equation::poend_out( poend_t, 3, UNIT_LENGTH() )
    spotr2  = TVF_NUM_FUN::parameter_equation::poend_out( poend_t, 4, UNIT_LENGTH() )
    spobl2  = TVF_NUM_FUN::parameter_equation::poend_out( poend_b, 0, UNIT_LENGTH() )
    spobl1  = TVF_NUM_FUN::parameter_equation::poend_out( poend_b, 1, UNIT_LENGTH() )
    spob    = TVF_NUM_FUN::parameter_equation::poend_out( poend_b, 2, UNIT_LENGTH() )
    spobr1  = TVF_NUM_FUN::parameter_equation::poend_out( poend_b, 3, UNIT_LENGTH() )
    spobr2  = TVF_NUM_FUN::parameter_equation::poend_out( poend_b, 4, UNIT_LENGTH() )
#ENDIF
   nfin=TRUNC( ((W * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )
   LODX_1 = DFM_VEC_VAL( lod_PROP, "PER_1" )
   LODX_2 = DFM_VEC_VAL( lod_PROP, "PER_2" )
   sa = TVF_NUM_FUN( "calc_lod_sasb", "device_function", LODX_1, W, L, UNIT_LENGTH(), SCALE )
   sb = TVF_NUM_FUN( "calc_lod_sasb", "device_function", LODX_2, W, L, UNIT_LENGTH(), SCALE )
   sa1 = TVF_NUM_FUN ( "calc_lod_sa1sb1", "device_function", LODX_1, W, L, UNIT_LENGTH(), SCALE )
   sb1 = TVF_NUM_FUN ( "calc_lod_sa1sb1", "device_function", LODX_2, W, L, UNIT_LENGTH(), SCALE )
   sa2 = TVF_NUM_FUN ( "calc_lod_sa2sb2", "device_function", LODX_1, W, L, UNIT_LENGTH(), SCALE )
   sb2 = TVF_NUM_FUN ( "calc_lod_sa2sb2", "device_function", LODX_2, W, L, UNIT_LENGTH(), SCALE )
   sa3 = TVF_NUM_FUN ( "calc_lod_sa3sb3", "device_function", LODX_1, W, L, UNIT_LENGTH(), SCALE )
   sb3 = TVF_NUM_FUN ( "calc_lod_sa3sb3", "device_function", LODX_2, W, L, UNIT_LENGTH(), SCALE )
   PI_S_OD = perimeter_inside(S,nthin)
   PI_D_OD = perimeter_inside(D,nthin)
   IF(PI_S_OD == 0) {
    AD = area(D) * W / PI_D_OD
    AS = AD
    PD = perimeter(D) * W /PI_D_OD
    PS = PD } 
   ELSE IF(PI_D_OD == 0) {
    AS = area(S) * W / PI_S_OD
    AD = AS
    PS = perimeter(S) * W /PI_S_OD
    PD = PS } 
   ELSE {
    AS = area(S) * W / PI_S_OD
    AD = area(D) * W / PI_D_OD
    PS = perimeter(S) * W /PI_S_OD
    PD = perimeter(D) * W /PI_D_OD }
   NRS = 0
   NRD = 0
// Well proximity.
   WPEX_1 = DFM_VEC_VAL( nCore_WPEPROP, "PER_1" )
   WPEX_2 = DFM_VEC_VAL( nCore_WPEPROP, "PER_2" )
   WPEY_1 = DFM_VEC_VAL( nCore_WPEPROP, "PAR_1" )
   WPEY_2 = DFM_VEC_VAL( nCore_WPEPROP, "PAR_2" )
   sca = TVF_NUM_FUN( "calc_sca2_dfm", "device_function", WPEX_1, WPEX_2, WPEY_1, WPEY_2, W, L, LR_EXT, TOP_EXT, BOT_EXT, UNIT_LENGTH(), SCALE, WPED )
   scb = TVF_NUM_FUN( "calc_scb2_dfm", "device_function", WPEX_1, WPEX_2, WPEY_1, WPEY_2, W, L, LR_EXT, TOP_EXT, BOT_EXT, UNIT_LENGTH(), SCALE, WPED )
   scc = TVF_NUM_FUN( "calc_scc2_dfm", "device_function", WPEX_1, WPEX_2, WPEY_1, WPEY_2, W, L, LR_EXT, TOP_EXT, BOT_EXT, UNIT_LENGTH(), SCALE, WPED )
   snet = PIN_NET(s)
   dnet = PIN_NET(d)
   net1 = DFM_NUM_VAL( gate_COR, "NET_1" )
   net2 = DFM_NUM_VAL( gate_COR, "NET_2" )
   if ( snet == net1 ) {
      is_rotated = 0
   } else {
      is_rotated = 1
   }
   lrange = DFM_VEC_VAL( gate_COR, "LRANGE" )
   lrange2 = DFM_VEC_VAL( gate_COR, "LRANGE2" )
   wrange = DFM_VEC_VAL( gate_COR, "WRANGE" )
   maxsd  = DFM_VEC_VAL( gate_COR, "MAX_SD" )
       #IFNDEF SKIP_PLE
      pse1       = DFM_VEC_VAL( gate_COR, "PSE1" )
      pse2       = DFM_VEC_VAL( gate_COR, "PSE2" )
      pse_str    = TVF_STR_FUN::parameter_equation::pse_pre( pse1, pse2, wrange, is_rotated, maxsd, UNIT_LENGTH() )
      ploda1     = TVF_NUM_FUN::parameter_equation::ploda1( pse_str, W, UNIT_LENGTH(), SCALE )
      ploda2     = TVF_NUM_FUN::parameter_equation::ploda2( pse_str, W, UNIT_LENGTH(), SCALE )
      ploda3     = TVF_NUM_FUN::parameter_equation::ploda3( pse_str, W, UNIT_LENGTH(), SCALE )
      plodb1     = TVF_NUM_FUN::parameter_equation::plodb1( pse_str, W, UNIT_LENGTH(), SCALE )
      plodb2     = TVF_NUM_FUN::parameter_equation::plodb2( pse_str, W, UNIT_LENGTH(), SCALE )
      plodb3     = TVF_NUM_FUN::parameter_equation::plodb3( pse_str, W, UNIT_LENGTH(), SCALE )
    #ENDIF
   #IFNDEF SKIP_ODSE
      // OD to OD
      G2ODX_1 = DFM_VEC_VAL( ngate_PROP, "LPEPER_1" )
      G2ODX_2 = DFM_VEC_VAL( ngate_PROP, "LPEPER_2" )
      G2ODY_1 = DFM_VEC_VAL( ngate_PROP, "LPEPAR_1" )
      G2ODY_2 = DFM_VEC_VAL( ngate_PROP, "LPEPAR_2" )
      sodxa  = TVF_NUM_FUN ( "compute_sodxab_clamp5", "parameter_equation", G2ODX_1, W, L, UNIT_LENGTH(), SCALE )
      sodxb  = TVF_NUM_FUN ( "compute_sodxab_clamp5", "parameter_equation", G2ODX_2, W, L, UNIT_LENGTH(), SCALE )
      sodxa1 = TVF_NUM_FUN ( "compute_sodxab1_clamp5","parameter_equation", G2ODX_1, W, L, UNIT_LENGTH(), SCALE )
      sodxb1 = TVF_NUM_FUN ( "compute_sodxab1_clamp5","parameter_equation", G2ODX_2, W, L, UNIT_LENGTH(), SCALE )
      sodxa2 = TVF_NUM_FUN ( "compute_sodxab2_clamp5","parameter_equation", G2ODX_1, W, L, UNIT_LENGTH(), SCALE )
      sodxb2 = TVF_NUM_FUN ( "compute_sodxab2_clamp5","parameter_equation", G2ODX_2, W, L, UNIT_LENGTH(), SCALE )
      sodxa4 = TVF_NUM_FUN ( "compute_sodxab4_clamp5","parameter_equation", G2ODX_1, W, L, UNIT_LENGTH(), SCALE )
      sodxb4 = TVF_NUM_FUN ( "compute_sodxab4_clamp5","parameter_equation", G2ODX_2, W, L, UNIT_LENGTH(), SCALE )
      sa5    = TVF_NUM_FUN ( "compute_sab5_clamp5",   "parameter_equation", G2ODX_1, W, L, UNIT_LENGTH(), SCALE )
      sb5    = TVF_NUM_FUN ( "compute_sab5_clamp5",   "parameter_equation", G2ODX_2, W, L, UNIT_LENGTH(), SCALE )
      sa6    = TVF_NUM_FUN ( "compute_sab6_clamp5",   "parameter_equation", G2ODX_1, W, L, UNIT_LENGTH(), SCALE )
      sb6    = TVF_NUM_FUN ( "compute_sab6_clamp5",   "parameter_equation", G2ODX_2, W, L, UNIT_LENGTH(), SCALE )
      sa7    = TVF_NUM_FUN ( "compute_sab7_clamp5",   "parameter_equation", G2ODX_1, W, L, UNIT_LENGTH(), SCALE )
      sb7    = TVF_NUM_FUN ( "compute_sab7_clamp5",   "parameter_equation", G2ODX_2, W, L, UNIT_LENGTH(), SCALE )
      wose1left  = DFM_VEC_VAL( gate_COR, "W_DIR_OD1LEFT" )
      wose1mid   = DFM_VEC_VAL( gate_COR, "W_DIR_OD1MID" )
      wose1right = DFM_VEC_VAL( gate_COR, "W_DIR_OD1RIGHT" )
      sodyb      = TVF_NUM_FUN::parameter_equation::sodytb( wose1left, wose1mid, wose1right, lrange, 2, is_rotated, UNIT_LENGTH(), SCALE, maxsd, L)
      wose2left  = DFM_VEC_VAL( gate_COR, "W_DIR_OD2LEFT" )
      wose2mid   = DFM_VEC_VAL( gate_COR, "W_DIR_OD2MID" )
      wose2right = DFM_VEC_VAL( gate_COR, "W_DIR_OD2RIGHT" )
      sodyt      = TVF_NUM_FUN::parameter_equation::sodytb( wose2left, wose2mid, wose2right, lrange2, 2, is_rotated, UNIT_LENGTH(), SCALE, maxsd, L)
   #ENDIF
   #IFNDEF SKIP_MBE
      mbe_net1 = DFM_NUM_VAL( ngate_mbe, "NET_1" )
      mbe_net2 = DFM_NUM_VAL( ngate_mbe, "NET_2" )
      if(snet == mbe_net1) {
         mbe_is_rotated = 0
      } else {
         mbe_is_rotated = 1
      }
      mbe_maxsd  = DFM_VEC_VAL( ngate_mbe, "MAX_SD" )
      mbe_lrange = DFM_VEC_VAL( ngate_mbe, "LRANGE" )
      mbe1       = DFM_VEC_VAL( ngate_mbe, "MULTI_LAYER_1" )
      mbe2       = DFM_VEC_VAL( ngate_mbe, "MULTI_LAYER_2" )
      mbe_str    = TVF_STR_FUN::parameter_equation::mbe_pre( mbe1, mbe2, mbe_lrange, mbe_is_rotated, UNIT_LENGTH(), mbe_maxsd )
      smbt = TVF_NUM_FUN::parameter_equation::smbt( mbe_str, L, UNIT_LENGTH(), SCALE )
      smbb = TVF_NUM_FUN::parameter_equation::smbb( mbe_str, L, UNIT_LENGTH(), SCALE )
   #ENDIF
]
