        gdis_b = gdis_b_ori - 0.12e-6
        gdis_l = gdis_l_ori - 0.12e-6
        gdis_r = gdis_r_ori - 0.12e-6
     }
   }
  #ENDIF
]
#IFDEF RC_DECK
DEVICE crtmom_wo_rf rmom3_rf_reg_shield9 cmom3p(PLUS) cmom3m(MINUS) M1(BULK) (PLUS MINUS) <MOMDMY_MXA> <MOMDMY_MXD> <MOMDMY_VAP> <MOM_LAYER_8> <SHIELD_LAYER> <nhnv_1st> <nhnv_2nd> <grflag_aux> <rtmom_SOB> [
#ELSE
DEVICE crtmom_wo_rf rmom3_rf_reg_shield9 cmom3p(PLUS) cmom3m(MINUS) M1(BULK) (PLUS MINUS) <MOMDMY_MXA> <MOMDMY_MXD> <MOMDMY_VAP> <MOM_LAYER_8> <SHIELD_LAYER> <nhnv_1st> <nhnv_2nd> <grflag_aux> [
#ENDIF
    property stm,vapmod,spm,nv,nh,n_mxa,mxd_flag,shield,grflag
  #IFDEF RC_DECK
    ,gdis_t,gdis_b,gdis_l,gdis_r
  #ENDIF
    nhnv1   = count(nhnv_1st)
    nhnv2   = count(nhnv_2nd)
    stm     = 3
    spm     = (perimeter(MOM_LAYER_8)/2 - (1e-9)) / 1e-9
    vapmod1 = ( perimeter(MOMDMY_VAP) * (1e+6) ) / 2 - 0.05
    if( vapmod1 < 0.051 ) {
	vapmod = 0
    } else {
	vapmod = vapmod1 / 0.1
    }
    mxd_flag1 = ( perimeter(MOMDMY_MXD) * (1e+6) ) / 2 - 0.05
    if( mxd_flag1 < 0.051 ) {
	mxd_flag = 0
    } else {
	mxd_flag = mxd_flag1 / 0.1
    }
    n_mxa1    = ( perimeter(MOMDMY_MXA) * (1e+6) ) / 2 - 0.05
    if( n_mxa1 < 0.051 ) { 
	n_mxa = 0
    } else {
	n_mxa = n_mxa1 / 0.1
    }
    shield = (perimeter(SHIELD_LAYER)/2 - (1e-8)) / 1e-8
    if( mxd_flag > 1 ) {
        nh = nhnv1
        nv = nhnv2
    } else {
        nv = nhnv1
        nh = nhnv2
    }
    if ( area(grflag_aux) > area(MOMDMY_VAP) ) { grflag = 0 } ELSE { grflag = 1 }
  #IFDEF RC_DECK
   gdis_t = 0
   gdis_b = 0
   gdis_l = 0
   gdis_r = 0
   RFX_1 = DFM_VEC_VAL( rtmom_SOB, "PER_1" )
   RFX_2 = DFM_VEC_VAL( rtmom_SOB, "PER_2" )
   RFY_1 = DFM_VEC_VAL( rtmom_SOB, "PAR_1" )
   RFY_2 = DFM_VEC_VAL( rtmom_SOB, "PAR_2" )
   gdis_t_ori = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_1, UNIT_LENGTH())
   gdis_b_ori = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_2, UNIT_LENGTH())
   gdis_l_ori = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_1, UNIT_LENGTH())
   gdis_r_ori = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_2, UNIT_LENGTH())
   if ( gdis_t_ori == 0.00015  &&  gdis_b_ori == 0.00015  &&  gdis_l_ori == 0.00015  && gdis_r_ori == 0.00015 ) {
     if ( grflag == 1 ) {
        gdis_t = 0.175e-6
        gdis_b = 0.175e-6
        gdis_l = 0.102e-6
        gdis_r = 0.102e-6
     } else {
        gdis_t = 0.00015
        gdis_b = 0.00015
        gdis_l = 0.00015
        gdis_r = 0.00015
     }
   } else {
     if( mxd_flag > 1 ) {
        gdis_t = gdis_l_ori - 0.12e-6
        gdis_b = gdis_r_ori - 0.12e-6
        gdis_l = gdis_t_ori - 0.12e-6
        gdis_r = gdis_b_ori - 0.12e-6
     } else {
        gdis_t = gdis_t_ori - 0.12e-6
        gdis_b = gdis_b_ori - 0.12e-6
        gdis_l = gdis_l_ori - 0.12e-6
        gdis_r = gdis_r_ori - 0.12e-6
     }
   }
  #ENDIF
]






DEVICE csfmom_2t fmom4_reg_2t_sf mom4p_sf(PLUS) mom4m_sf(MINUS) <MOM_field4> <MOMDMY_MXA> <MOMDMY_MXD> <MOM_LAYER_8> <mom4_extc_csf> <SMOM_hole4>  [
    property w,s,nr,lr,stm,spm,n_mxa,n_mxd
    nr = count(MOM_field4) + 2 
    w       = perimeter_coincide(MOM_field4, fmom4_reg_2t_sf) / (nr-2)
    ftip    = AREA(mom4_extc_csf) / (nr-2) / w
    l       = AREA(MOM_field4) / (nr-2) / w
    s       = AREA(SMOM_hole4) / (nr-1) / (ftip+l)
    lr      = perimeter(SMOM_hole4) / 2 / (nr-1) - s - 2 * ftip
    stm = 4
    spm = (perimeter(MOM_LAYER_8)/2 - (1e-9)) / 1e-9
        n_mxd1 = ( perimeter(MOMDMY_MXD) * (1e+6) ) / 2 - 0.05
    if( n_mxd1 < 0.051 ) {
	n_mxd = 0
    } else {
	n_mxd = n_mxd1 / 0.1
    }
    n_mxa1    = ( perimeter(MOMDMY_MXA) * (1e+6) ) / 2 - 0.05
    if( n_mxa1 < 0.051 ) { 
	n_mxa = 0
    } else {
	n_mxa = n_mxa1 / 0.1
    }
]




