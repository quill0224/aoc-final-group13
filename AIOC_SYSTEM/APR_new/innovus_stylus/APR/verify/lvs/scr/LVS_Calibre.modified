//***** Define connectivity/via layer -- n_gpoly_io ****
n_gpoly_io_all = npoly_io NOT n_fpoly_io 
n_gpoly_io1 = n_gpoly_io_all NOT all_mos_gates 
nocg_dmy1 = BJTDMY OR DIODMY 
nocg_dmy2 = COPY nocg_dmy1 
nocg_dmy3 = nocg_dmy2 OR HIA_DUMMY 
nocg_dmy = nocg_dmy3 OR SDI_FOD 
n_gpoly_nocg_io = n_gpoly_io1 AND nocg_dmy 
n_gpoly_io2 = n_gpoly_io1 NOT n_gpoly_nocg_io 
n_gpoly_io = n_gpoly_io2 NOT ngate_mbscr 

//* Define device -- xdev moscap_rf18_110g
vargt_rf18a = vargt_rf2 AND OD18 
vargt_rf18 = vargt_rf18a AND NP  //  RF Varactor on 1.8v thick oxide

//* Define device -- xdev moscap_rf
var_nw_rf_seed_all = var_nw_rfa AND DNW 
var_nw_rf_seed = var_nw_rf_seed_all NOT INTERACT RFDMY_mmW  //  RF dmos nmoscap core 0.8v w/i DNW

//* Define device -- xdev moscap_rf18
