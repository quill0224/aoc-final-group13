        gdis_t = gdis_t_ori - 0.12e-6
        gdis_b = gdis_b_ori - 0.12e-6
        gdis_l = gdis_l_ori - 0.12e-6
        gdis_r = gdis_r_ori - 0.12e-6
     }
   }
  #ENDIF
]
