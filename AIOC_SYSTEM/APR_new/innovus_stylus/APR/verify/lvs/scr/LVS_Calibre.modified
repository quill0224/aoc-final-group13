unrecognized_nwsti_1 = NWDMY NOT valid_nwdmy_1 
valid_nwdmy_2 = NWDMY1 INTERACT nwsti_mr 
unrecognized_nwsti_2 = unrecognized_nwsti_1 NOT valid_nwdmy_2 
