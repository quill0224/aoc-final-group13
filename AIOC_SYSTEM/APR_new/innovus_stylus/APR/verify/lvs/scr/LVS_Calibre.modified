DEVICE cfmom_wo_p80 fmom3_reg_pw_p80_dm M3(PLUS) M3(MINUS) psub(BULK) <MOM_field3> <mom3_extc>   <dmetal1> <dmetal2> <MOMDMY_VAP> <MOMDMY_MXA> <MOMDMY_MXD> <MOM_LAYER_8> <SHIELD_LAYER> <MOM_hole3> <grflag_aux> (PLUS MINUS) [
#ENDIF
    property nr,lr,stm,spm,dmflag,vapmod,n_mxa,mxd_flag,shield,grflag
  #IFDEF RC_DECK
    ,gdis_t,gdis_b,gdis_l,gdis_r
  #ENDIF

    nr = count(MOM_field3)
    w       = perimeter_coincide(MOM_field3, fmom3_reg_pw_p80_dm) / nr
    ftip    = AREA(mom3_extc) / nr / w
    s       = perimeter_coincide(MOM_hole3, fmom3_reg_pw_p80_dm) / (nr-1) / 2
    lr      = perimeter(MOM_hole3) / 2 / (nr-1) - s - 2 * ftip
    stm = 3
    spm = (perimeter(MOM_LAYER_8)/2 - (1e-9)) / 1e-9
    vapmod1 = ( perimeter(MOMDMY_VAP) * (1e+6) ) / 2 - 0.05
    if( vapmod1 < 0.051 ) {
	vapmod = 0
    } else {
	vapmod = vapmod1 / 0.1
    }
    mxd_flag1 = ( perimeter(MOMDMY_MXD) * (1e+6) ) / 2 - 0.05
    if( mxd_flag1 < 0.051 ) {
	mxd_flag = 0
    } else {
	mxd_flag = mxd_flag1 / 0.1
    }
    if ( area(grflag_aux) > area(MOMDMY_VAP) ) { grflag = 0 } ELSE { grflag = 1 }
  #IFDEF RC_DECK
   gdis_t = 0
   gdis_b = 0
   gdis_l = 0
   gdis_r = 0
   RFX_1 = DFM_VEC_VAL( mom_SOB, "PER_1" )
   RFX_2 = DFM_VEC_VAL( mom_SOB, "PER_2" )
   RFY_1 = DFM_VEC_VAL( mom_SOB, "PAR_1" )
   RFY_2 = DFM_VEC_VAL( mom_SOB, "PAR_2" )
   gdis_t = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_1, UNIT_LENGTH())
   gdis_b = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_2, UNIT_LENGTH())
   gdis_l = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_1, UNIT_LENGTH())
   gdis_r = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_2, UNIT_LENGTH())
   if ( gdis_t == 0.00015  &&  gdis_b == 0.00015  &&  gdis_l == 0.00015  && gdis_r == 0.00015 ) {
     if ( grflag == 1 ) {
        gdis_t = 0.175e-6
        gdis_b = 0.175e-6
        gdis_l = 0.102e-6
        gdis_r = 0.102e-6
     }
   } else {
        gdis_t = gdis_t - 0.12e-6
        gdis_b = gdis_b - 0.12e-6
        gdis_l = gdis_l + 0.005e-6
        gdis_r = gdis_r + 0.005e-6
   }
  #ENDIF


    n_mxa1    = ( perimeter(MOMDMY_MXA) * (1e+6) ) / 2 - 0.05
    if( n_mxa1 < 0.051 ) { 
	n_mxa = 0
    } else {
	n_mxa = n_mxa1 / 0.1
    }
    shield = (perimeter(SHIELD_LAYER)/2 - (1e-8)) / 1e-8
    ftip = AREA(mom3_extc)/(nr*w)
    moml = lr + 2*ftip
    momw = (perimeter(fmom3_reg_pw_p80_dm) - (2*moml))/2
    xlen = momw + (2*DX_P80*1e-6)
    ylen = moml + (2*DY_P80*1e-6)
    dmmax = 0
    dmmin = 1
    dm1 = area(dmetal1) / (xlen * ylen )
    IF( dm1 < dmmin ) { dmmin = dm1 }
    IF( dm1 > dmmax ) { dmmax = dm1 }
    dm2 = area(dmetal2) / (xlen * ylen )
    IF( dm2 < dmmin ) { dmmin = dm2 }
    IF( dm2 > dmmax ) { dmmax = dm2 }
    IF( dmmax > 0.17 && dmmax < 0.19 && dmmin > 0.17 && dmmin < 0.19 ) {
       dmflag = 1
    } ELSE {
       dmflag = 99
    }
]

