rfdmy6t_odnum_b = rfdmy6t_odnum_a NOT RFDMY5T 
rfdmy6t_odnum = rfdmy6t_odnum_b NOT RFDMYGR 

//***** Define connectivity/via layer -- n_fptap_hvt ****
