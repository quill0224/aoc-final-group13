#ELSE
DEVICE rhimw_rf_110g rhimw_rf_r_110g RH_TN(HI) RH_TN(LO) nxwell(GNODE) (HI LO) [
#ENDIF
property l,w
  #IFDEF RC_DECK
    ,gdis_t,gdis_b,gdis_l,gdis_r,rotation_flag
  #ENDIF

  #IFDEF RC_DECK
   gdis_t = 0
   gdis_b = 0
   gdis_l = 0
   gdis_r = 0
   RFX_1 = DFM_VEC_VAL( rfres_SOB, "PAR_1" )
   RFX_2 = DFM_VEC_VAL( rfres_SOB, "PAR_2" )
   RFY_1 = DFM_VEC_VAL( rfres_SOB, "PER_1" )
   RFY_2 = DFM_VEC_VAL( rfres_SOB, "PER_2" )

   len_rotation_aux = perimeter(rotation_aux)/2 - MINGRID_RECT1_UNIT
   rotation_flag = 0
   if(len_rotation_aux > MINGRID_RECT1_01_UNIT) {
   rotation_flag = 1
   }
   if (rotation_flag == 1) {
   gdis_l = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_1, UNIT_LENGTH())
   gdis_r = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_2, UNIT_LENGTH())
   gdis_b = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_1, UNIT_LENGTH())
   gdis_t = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_2, UNIT_LENGTH())

   if ( gdis_l == 0.00015  &&  gdis_r == 0.00015  &&  gdis_b == 0.00015  && gdis_t == 0.00015 ) {
        gdis_l = 0.446e-6
        gdis_r = 0.446e-6
        gdis_b = 0.903e-6
        gdis_t = 0.903e-6
   } else {
        gdis_l = gdis_l - 0.125e-6
        gdis_r = gdis_r - 0.125e-6
   } 
   } else {
   gdis_t = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_1, UNIT_LENGTH())
   gdis_b = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_2, UNIT_LENGTH())
   gdis_l = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_1, UNIT_LENGTH())
   gdis_r = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_2, UNIT_LENGTH())

   if ( gdis_t == 0.00015  &&  gdis_b == 0.00015  &&  gdis_l == 0.00015  && gdis_r == 0.00015 ) {
        gdis_t = 0.446e-6
        gdis_b = 0.446e-6
        gdis_l = 0.903e-6
        gdis_r = 0.903e-6
   } else {
        gdis_t = gdis_t - 0.125e-6
        gdis_b = gdis_b - 0.125e-6
   } 
   }
  #ENDIF

  w = perimeter_coincide(rhimw_rf_r_110g,RH_TN)/2
  l = area(rhimw_rf_r_110g)/w
]
