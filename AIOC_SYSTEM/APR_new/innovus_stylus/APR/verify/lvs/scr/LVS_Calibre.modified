   gdis_r_ori = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_2, UNIT_LENGTH())
   if ( gdis_t_ori == 0.00015  &&  gdis_b_ori == 0.00015  &&  gdis_l_ori == 0.00015  && gdis_r_ori == 0.00015 ) {
     if ( grflag == 1 ) {
        gdis_t = 0.175e-6
        gdis_b = 0.175e-6
        gdis_l = 0.102e-6
        gdis_r = 0.102e-6
     } else {
        gdis_t = 0.00015
        gdis_b = 0.00015
        gdis_l = 0.00015
        gdis_r = 0.00015
     }
   } else {
     if( mxd_flag > 1 ) {
        gdis_t = gdis_l_ori - 0.12e-6
        gdis_b = gdis_r_ori - 0.12e-6
        gdis_l = gdis_t_ori - 0.12e-6
        gdis_r = gdis_b_ori - 0.12e-6
