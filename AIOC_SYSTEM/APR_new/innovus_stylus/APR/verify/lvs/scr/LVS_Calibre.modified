NT_N_DUM_INT = DFM SPACE NTN_RNG <= 50 BY INT 
NT_N_DUM_INNER = HOLES NTN_RNG INNER 
NT_N_DUM_P = DFM PROPERTY NTN_RNG NT_N_DUM_INT OVERLAP ABUT ALSO 
[ min_ntn_1 = min(EW(NT_N_DUM_INT)) ] 
NT_N_DUM_INNER_P = DFM PROPERTY NT_N_DUM_INNER NT_N_DUM_P  OVERLAP ABUT ALSO 
[ min_ntn_2 = PROPERTY(NT_N_DUM_P,min_ntn_1) ]
OD_NT_N_DUM_W = DFM PROPERTY OD NT_N_DUM_INNER_P  OVERLAP ABUT ALSO MULTI 
[ min_ntn_w = PROPERTY(NT_N_DUM_INNER_P,min_ntn_2) ]


DEVICE pdio_18_mac pdio_18_r tpdiff_dio(PLUS) nxwell(MINUS) [
	property nfin, l
        #IFDEF EXTRACT_W
	,w
        #ENDIF
	diffn = count(tpdiff_dio)
	w = perimeter_inside(tpdiff_dio,pdio_18_r) / 2 / diffn
	l = area(pdio_18_r) / w
        nfin = TRUNC( ((w * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )	
]
TRACE PROPERTY pdio_18_mac nfin   nfin   DIO_NFINerr
TRACE PROPERTY pdio_18_mac l      l      DIO_Lerr

DEVICE pdio_gated18_mac pgdio tpdiff_dio(PLUS) nxwell(MINUS) <pgate_gdio_2t> <npdiff_gdio> <pdiff_gdio>  [  
  property nfin,dw,nr
  #IFDEF EXTRACT_W
  ,wg
  #ENDIF

  gr = count(pdiff_gdio)
  nr = count(pgate_gdio_2t)
  wg = perimeter_coincide(npdiff_gdio,pgate_gdio_2t)/nr/2
  nfin = TRUNC( ((wg * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )
  dw = area(npdiff_gdio)/wg/(nr+gr)
]  
TRACE PROPERTY pdio_gated18_mac nfin nfin 0
TRACE PROPERTY pdio_gated18_mac dw   dw   0
TRACE PROPERTY pdio_gated18_mac nr   nr   0

#IFDEF RC_DECK
DEVICE pdio_gated18_mac_rf pgdio_rf tpdiff_dio(ANODE) nxwell(CATHODE) RFDMY_GATED_bulk(GNODE) <pgate_gdio_rf_3t> <npdiff_gdio_rf> <pdiff_gdio_rf> <rfdio_SOB>[  
#ELSE
DEVICE pdio_gated18_mac_rf pgdio_rf tpdiff_dio(ANODE) nxwell(CATHODE) RFDMY_GATED_bulk(GNODE) <pgate_gdio_rf_3t> <npdiff_gdio_rf> <pdiff_gdio_rf> [  
#ENDIF
  property dw,nfin,nf,gr
  #IFDEF EXTRACT_W
  ,wg
  #ENDIF
  #IFDEF RC_DECK
    ,sobn,sobs,sobw,sobe

   sobn = 0
   sobs = 0
   sobw = 0
   sobe = 0
   RFX_1 = DFM_VEC_VAL( rfdio_SOB, "PER_1" )
   RFX_2 = DFM_VEC_VAL( rfdio_SOB, "PER_2" )
   RFY_1 = DFM_VEC_VAL( rfdio_SOB, "PAR_1" )
   RFY_2 = DFM_VEC_VAL( rfdio_SOB, "PAR_2" )
   sobn = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_1, UNIT_LENGTH())
   sobs = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_2, UNIT_LENGTH())
   sobw = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_1, UNIT_LENGTH())
   sobe = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_2, UNIT_LENGTH())
  #ENDIF


  gr = count(pdiff_gdio_rf)
  nf = count(pgate_gdio_rf_3t)/gr
  wg = perimeter_coincide(npdiff_gdio_rf,pgate_gdio_rf_3t)/gr/(nf-1)/2
  nfin = TRUNC( ((wg * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )
  dw = area(npdiff_gdio_rf)/gr/(nf-1)/wg
]  
TRACE PROPERTY pdio_gated18_mac_rf dw   dw   0
TRACE PROPERTY pdio_gated18_mac_rf nfin nfin 0
TRACE PROPERTY pdio_gated18_mac_rf nf   nf   0
TRACE PROPERTY pdio_gated18_mac_rf gr   gr   0

DEVICE pdio_hia18_mac hia_pdio_r tpdiff_dio(PLUS) nxwell(MINUS) <hia_dio_pgate> [
  property l,nfin,nf
  #IFDEF EXTRACT_W
  ,w
  #ENDIF

  nf = count(tpdiff_dio)
  w = perimeter_coincide(tpdiff_dio,hia_dio_pgate)/nf/2
  nfin = TRUNC( ((w * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )
  l = area(tpdiff_dio)/nf/w
]
TRACE PROPERTY pdio_hia18_mac nfin  nfin  DIO_NFINerr
TRACE PROPERTY pdio_hia18_mac l     l     DIO_Lerr
TRACE PROPERTY pdio_hia18_mac nf    nf    0

#IFDEF RC_DECK
DEVICE pdio_hia18_mac_rf hia_pdio_r_rf tpdiff_dio(ANODE) nxwell(CATHODE) RFDMY_HIA_bulk(GNODE) <hia_dio_pgate_rf> <pdiff_hiadio_rf> <rfdio_SOB> [
#ELSE
DEVICE pdio_hia18_mac_rf hia_pdio_r_rf tpdiff_dio(ANODE) nxwell(CATHODE) RFDMY_HIA_bulk(GNODE) <hia_dio_pgate_rf> <pdiff_hiadio_rf> [
#ENDIF
  property aw,nfin,fn,gr
  #IFDEF EXTRACT_W
  ,al
  #ENDIF
  #IFDEF RC_DECK
    ,sobn,sobs,sobw,sobe

   sobn = 0
   sobs = 0
   sobw = 0
   sobe = 0
   RFX_1 = DFM_VEC_VAL( rfdio_SOB, "PER_1" )
   RFX_2 = DFM_VEC_VAL( rfdio_SOB, "PER_2" )
   RFY_1 = DFM_VEC_VAL( rfdio_SOB, "PAR_1" )
   RFY_2 = DFM_VEC_VAL( rfdio_SOB, "PAR_2" )
   sobn = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_1, UNIT_LENGTH())
   sobs = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_2, UNIT_LENGTH())
   sobw = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_1, UNIT_LENGTH())
   sobe = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_2, UNIT_LENGTH())
  #ENDIF


  gr = count(pdiff_hiadio_rf)
  fn = count(hia_dio_pgate_rf)/gr
  al = perimeter_coincide(tpdiff_dio,hia_dio_pgate_rf)/gr/(fn-1)/2
  nfin = TRUNC( ((al * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )
  aw = area(tpdiff_dio)/gr/(fn-1)/al
]
TRACE PROPERTY pdio_hia18_mac_rf nfin  nfin  DIO_NFINerr
TRACE PROPERTY pdio_hia18_mac_rf aw    aw    DIO_Lerr
TRACE PROPERTY pdio_hia18_mac_rf fn    fn    0
TRACE PROPERTY pdio_hia18_mac_rf gr    gr    0


DEVICE pdio_mac pdio_r tpdiff_dio(PLUS) nxwell(MINUS) [
	property nfin, l
        #IFDEF EXTRACT_W
	,w
        #ENDIF
	diffn = count(tpdiff_dio)
	w = perimeter_inside(tpdiff_dio,pdio_r) / 2 / diffn
	l = area(pdio_r) / w
        nfin = TRUNC( ((w * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )	
]
TRACE PROPERTY pdio_mac nfin   nfin   DIO_NFINerr
TRACE PROPERTY pdio_mac l      l      DIO_Lerr

DEVICE pmbscr_mac pmbscr_mac_reg d_tpdiff_mbscr(D) pgate_mbscr(G) s_tpdiff_mbscr(S) <npdiff_mbscr> <pdiff_mbscr> [  
  property l,nfin,nr,nf
  #IFDEF EXTRACT_W
  ,w
  #ENDIF

  nf = count(pdiff_mbscr)
  nr = count(pgate_mbscr)
  w = perimeter_coincide(npdiff_mbscr,pgate_mbscr)/nr/2
  l  = area(pgate_mbscr) / nr / w
  nfin = TRUNC( ((w * 1e6 - FIN_WIDTH) / FIN_PITCH ) + 1.01 )
]  
TRACE PROPERTY pmbscr_mac l    l 0
TRACE PROPERTY pmbscr_mac nfin nfin 0
TRACE PROPERTY pmbscr_mac nr   nr   0
TRACE PROPERTY pmbscr_mac nf   nf   0

