   property nfin,L
   #IFDEF EXTRACT_W
   ,W
   #ENDIF
   SCALE = PRESCALE
   W=(perimeter_coincide(ngate_pd_hpsr_mac, tndiff ) + perimeter_inside(ngate_pd_hpsr_mac, tndiff)) / 2
   L=area(ngate_pd_hpsr_mac) / W
   nfin = count(ODs)
   W = (FIN_WIDTH + ( nfin - 1) * FIN_PITCH) * 1e-6
]

