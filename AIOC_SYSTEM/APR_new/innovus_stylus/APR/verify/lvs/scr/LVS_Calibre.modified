var_nw_rf1a = VAR_RF AND nxwell 
diff_invalid = diff1 NOT INTERACT MD_valid 
var_nw_rf0a = diff_invalid AND VAR_RF 
var_nw_rf0b = SIZE var_nw_rf0a BY 0.005 
var_nw_rf0c = SIZE Small_Poly2 BY 0.005 
