DEVICE ndio_18_mac ndio_18_r psub(PLUS) tndiff_dio(MINUS) [
	property nfin, l
        #IFDEF EXTRACT_W
	,w
        #ENDIF
	diffn = count(tndiff_dio)
	w = perimeter_inside(tndiff_dio,ndio_18_r) / 2 / diffn
	l = area(ndio_18_r) / w
        nfin = TRUNC( ((w * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )	
]
TRACE PROPERTY ndio_18_mac nfin   nfin   DIO_NFINerr
TRACE PROPERTY ndio_18_mac l      l      DIO_Lerr

DEVICE ndio_gated18_mac ngdio psub(PLUS) tndiff_dio(MINUS) <ngate_gdio> <npdiff_gdio> <ndiff_gdio>  [  
  property nfin,dw,nr
  #IFDEF EXTRACT_W
  ,wg
  #ENDIF

  gr = count(ndiff_gdio)
  nr = count(ngate_gdio)
  wg = perimeter_coincide(npdiff_gdio,ngate_gdio)/nr/2
  nfin = TRUNC( ((wg * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )
  dw = area(npdiff_gdio)/wg/(nr+gr)
]  
TRACE PROPERTY ndio_gated18_mac nfin nfin 0
TRACE PROPERTY ndio_gated18_mac dw   dw   0
TRACE PROPERTY ndio_gated18_mac nr   nr   0

DEVICE ndio_gated18_mac_rf ngdio_rf psub(ANODE) tndiff_dio(CATHODE) <ngate_gdio_rf> <npdiff_gdio_rf> <ndiff_gdio_rf>  [  
  property dw,nfin,nf,gr
  #IFDEF EXTRACT_W
  ,wg
  #ENDIF

  gr = count(ndiff_gdio_rf)
  nf = count(ngate_gdio_rf)/gr
  wg = perimeter_coincide(npdiff_gdio_rf,ngate_gdio_rf)/gr/(nf-1)/2
  nfin = TRUNC( ((wg * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )
  dw = area(npdiff_gdio_rf)/gr/(nf-1)/wg
]  
TRACE PROPERTY ndio_gated18_mac_rf dw   dw   0
TRACE PROPERTY ndio_gated18_mac_rf nfin nfin 0
TRACE PROPERTY ndio_gated18_mac_rf nf   nf   0
TRACE PROPERTY ndio_gated18_mac_rf gr   gr   0

DEVICE ndio_hia18_mac hia_ndio_r psub(PLUS) tndiff_dio(MINUS) <hia_dio_ngate> [
  property l,nfin,nf
  #IFDEF EXTRACT_W
  ,w
  #ENDIF

  nf = count(tndiff_dio)
  w = perimeter_coincide(tndiff_dio,hia_dio_ngate)/nf/2
  nfin = TRUNC( ((w * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )
  l = area(tndiff_dio)/nf/w
]
TRACE PROPERTY ndio_hia18_mac nfin  nfin  DIO_NFINerr
TRACE PROPERTY ndio_hia18_mac l     l     DIO_Lerr
TRACE PROPERTY ndio_hia18_mac nf    nf    0

DEVICE ndio_hia18_mac_rf hia_ndio_r_rf psub(ANODE) tndiff_dio(CATHODE) <hia_dio_ngate_rf> <ndiff_hiadio_rf>  [
  property aw,nfin,fn,gr
  #IFDEF EXTRACT_W
  ,al
  #ENDIF
  gr = count(ndiff_hiadio_rf)
  fn = count(hia_dio_ngate_rf)/gr
  al = perimeter_coincide(tndiff_dio,hia_dio_ngate_rf)/gr/(fn-1)/2
  nfin = TRUNC( ((al * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )
  aw = area(tndiff_dio)/gr/(fn-1)/al
]
TRACE PROPERTY ndio_hia18_mac_rf nfin  nfin  DIO_NFINerr
TRACE PROPERTY ndio_hia18_mac_rf aw    aw    DIO_Lerr
TRACE PROPERTY ndio_hia18_mac_rf fn    fn    0
TRACE PROPERTY ndio_hia18_mac_rf gr    gr    0


DEVICE ndio_mac ndio_r psub(PLUS) tndiff_dio(MINUS) [
	property nfin, l
        #IFDEF EXTRACT_W
	,w
        #ENDIF
	diffn = count(tndiff_dio)
	w = perimeter_inside(tndiff_dio,ndio_r) / 2 / diffn
	l = area(ndio_r) / w
        nfin = TRUNC( ((w * 1e6 - FIN_WIDTH) / FIN_PITCH) + 1.01 )	
]
TRACE PROPERTY ndio_mac nfin   nfin   DIO_NFINerr
TRACE PROPERTY ndio_mac l      l      DIO_Lerr

DEVICE nfod_npwnw_mac nfod_r psub(PLUS) nxwell(MINUS) <sdi_fod_ngate> <nthin_nw> <tndiff_dio_sdi2> [  
  property l,nfin,nf
  #IFDEF EXTRACT_W
  ,w
  #ENDIF

  nf    = count(nthin_nw)
  diffn = count(tndiff_dio_sdi2)
  w = perimeter_coincide(sdi_fod_ngate,tndiff_dio_sdi2)/diffn/2
  l  = area(nthin_nw) / nf / w
  nfin = TRUNC( ((w * 1e6 - FIN_WIDTH) / FIN_PITCH ) + 1.01 )
]  
TRACE PROPERTY nfod_npwnw_mac l    l 0
TRACE PROPERTY nfod_npwnw_mac nfin nfin 0
TRACE PROPERTY nfod_npwnw_mac nf   nf   0

DEVICE nmbscr_mac nmbscr_mac_reg d_tndiff_mbscr(D) ngate_mbscr(G) s_tndiff_mbscr(S) <npdiff_mbscr> <ndiff_mbscr> [  
  property l,nfin,nr,nf
  #IFDEF EXTRACT_W
  ,w
  #ENDIF

  nf = count(ndiff_mbscr)
  nr = count(ngate_mbscr)
  w = perimeter_coincide(npdiff_mbscr,ngate_mbscr)/nr/2
  l  = area(ngate_mbscr) / nr / w
  nfin = TRUNC( ((w * 1e6 - FIN_WIDTH) / FIN_PITCH ) + 1.01 )
]  
TRACE PROPERTY nmbscr_mac l    l 0
TRACE PROPERTY nmbscr_mac nfin nfin 0
TRACE PROPERTY nmbscr_mac nr   nr   0
