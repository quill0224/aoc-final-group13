//***** Define connectivity/via layer -- n_fpoly_svt ****
poly1 = poly_org NOT poly_rf 
N_h_s_edge1 = VTH_N COINCIDENT EDGE VTS_N
N_h_s_edge2 = N_h_s_edge1 INSIDE EDGE Small_Poly3 
N_h_s_edge = N_h_s_edge1 TOUCH EDGE N_h_s_edge2
VTH_N_exp_hs = EXPAND EDGE N_h_s_edge OUTSIDE BY VT_SHIFTED_DISTANCE
VTSN1 = VTS_N NOT VTH_N_exp_hs 
VTL_N_rgn1 = VTL_N OR VTUL_N 
VTL_N_rgn2 = VTL_N_rgn1 OR Empty 
VTL_N_rgn3 = VTL_N_rgn2 OR Empty 
VTL_N_rgn = VTL_N_rgn3 OR VTLN_N 
N_s_l_edge1 = VTS_N COINCIDENT EDGE VTL_N_rgn
N_s_l_edge2 = N_s_l_edge1 INSIDE EDGE Small_Poly3 
N_s_l_edge = N_s_l_edge1 TOUCH EDGE N_s_l_edge2
VTS_N_exp = EXPAND EDGE N_s_l_edge OUTSIDE BY VT_SHIFTED_DISTANCE
VTSN = VTSN1 OR VTS_N_exp 
sram_n = SRAMDMY AND NP 
sram_p = SRAMDMY NOT sram_n 
sram_np = sram_n OR sram_p 
npoly_co_s1 = VTSN NOT sram_np 
VAR_and_NP = VARi AND NP 
npoly_co_s2 = npoly_co_s1 OR VAR_and_NP 
OD2 = COPY OD18 
npoly_co_s3 = npoly_co_s2 NOT OD2 
npoly_co_s = poly1 AND npoly_co_s3 
n_fpoly_svt = npoly_co_s NOT OD 

