DEVICE cfmom_mx_4t_p80 fmom2_mx_reg_4t_p80 mom2p1(PLUS1) mom2m1(MINUS1) mom2p2(PLUS2) mom2m2(MINUS2) <MOM_field2> <mom2_mx_aux> <mom2_extc> <MOMDMY_VAP> <MOMDMY_MXA> <MOMDMY_MXD> <MOM_LAYER_8> <MOM_hole2> [
    property nr,lr,stm,spm,multi,vapmod,n_mxa,mxd_flag
    mf1 = count(mom2_mx_aux)
    multi = mf1/2
    nr = count(MOM_field2)/mf1
    w       = perimeter_coincide(MOM_field2, mom2_mx_aux) / (nr*mf1)
    ftip    = AREA(mom2_extc) / (nr*mf1) / w
    s       = perimeter_coincide(MOM_hole2, mom2_mx_aux) / (mf1*(nr-1)) / 2
    lr      = perimeter(MOM_hole2) / 2 / (mf1*(nr-1)) - s - 2 * ftip    
    stm = 2
    spm = (perimeter(MOM_LAYER_8)/2 - (1e-9)) / 1e-9
    vapmod1 = ( perimeter(MOMDMY_VAP) * (1e+6) ) / (mf1*2) - 0.05
    if( vapmod1 < 0.051 ) {
	vapmod = 0
    } else {
	vapmod = vapmod1 / 0.1
    }
    mxd_flag1 = ( perimeter(MOMDMY_MXD) * (1e+6) ) / (mf1*2) - 0.05
    if( mxd_flag1 < 0.051 ) {
	mxd_flag = 0
    } else {
	mxd_flag = mxd_flag1 / 0.1
    }

    n_mxa1    = ( perimeter(MOMDMY_MXA) * (1e+6) ) / (mf1*2) - 0.05
    if( n_mxa1 < 0.051 ) { 
	n_mxa = 0
    } else {
	n_mxa = n_mxa1 / 0.1
    }
]












DEVICE crtmom_2t rmom2_reg_2t cmom2p(PLUS) cmom2m(MINUS) <MOMDMY_MXA> <MOMDMY_MXD> <MOMDMY_VAP> <MOM_LAYER_8> <nhnv_1st> <nhnv_2nd>  [
    property stm,vapmod,spm,nv,nh,n_mxa,mxd_flag
    nhnv1   = count(nhnv_1st)
    nhnv2   = count(nhnv_2nd)
    stm = 2
    spm     = (perimeter(MOM_LAYER_8)/2 - (1e-9)) / 1e-9
    vapmod1 = ( perimeter(MOMDMY_VAP) * (1e+6) ) / 2 - 0.05
    if( vapmod1 < 0.051 ) {
	vapmod = 0
    } else {
	vapmod = vapmod1 / 0.1
    }
    mxd_flag1 = ( perimeter(MOMDMY_MXD) * (1e+6) ) / 2 - 0.05
    if( mxd_flag1 < 0.051 ) {
	mxd_flag = 0
    } else {
	mxd_flag = mxd_flag1 / 0.1
    }
    n_mxa1    = ( perimeter(MOMDMY_MXA) * (1e+6) ) / 2 - 0.05
    if( n_mxa1 < 0.051 ) { 
	n_mxa = 0
    } else {
	n_mxa = n_mxa1 / 0.1
    }
    if( mxd_flag > 1 ) {
        nh = nhnv1
        nv = nhnv2
    } else {
        nv = nhnv1
        nh = nhnv2
    }
]
