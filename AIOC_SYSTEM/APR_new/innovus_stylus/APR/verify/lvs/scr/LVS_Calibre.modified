VIA0_M0_PO = VIA0_M0_PO1 INTERACT VIA0_M0_PO_com 
dumpo2 = dumpo1 NOT INTERACT VIA0_M0_PO 
gate1a = realpo NOT dumpo2 
gate1b = gate1a NOT RH_MG 
gate1 = gate1b AND mdiff 
