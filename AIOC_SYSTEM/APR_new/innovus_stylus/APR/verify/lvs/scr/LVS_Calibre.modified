DEVICE MP(pchpu_8tsr_mac) pgate_pu_8tsr_mac pgate_pu_8tsr_mac(G) tpdiff(S) tpdiff(D) nxwell(B) <pthin>  <ODs> netlist model pchpu_8tsr_mac netlist element "X" [
   property nfin,L
   #IFDEF EXTRACT_W
   ,W
   #ENDIF
   SCALE = PRESCALE
   W=(perimeter_coincide(pgate_pu_8tsr_mac, tpdiff ) + perimeter_inside(pgate_pu_8tsr_mac, tpdiff)) / 2
   L=area(pgate_pu_8tsr_mac) / W
   nfin = count(ODs)
   W = (FIN_WIDTH + ( nfin - 1) * FIN_PITCH) * 1e-6
]

