unrecognized_nwsti_body_with_od_1 = all_nwsti AND OD 
unrecognized_nwsti_body_with_od = all_nwsti INTERACT unrecognized_nwsti_body_with_od_1 
unrecognized_nwsti = unrecognized_nwsti_2 OR unrecognized_nwsti_body_with_od 

//***** Define connectivity/via layer -- mom5m1 ****
