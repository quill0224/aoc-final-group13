   W = (perimeter_coincide(nch_hvt_dnw_mac_gate, tndiff ) + perimeter_inside(nch_hvt_dnw_mac_gate, tndiff)) / 2
   L = area(nch_hvt_dnw_mac_gate) / W
   #IFDEF MATCHFLAG
      len_aux = perimeter(matching_aux)/2 - MINGRID_RECT1_UNIT
      matchingflag = 0.0
      edgeflag = 0.0
      if(len_aux > MINGRID_RECT1_01_UNIT) {
         edgeflag1 = (len_aux/MINGRID_RECT1_UNIT)/2-1
         if (edgeflag1 > 0.5) {
            edgeflag = 1
         } else {
            edgeflag = 0
         }
         matchingflag = 1
