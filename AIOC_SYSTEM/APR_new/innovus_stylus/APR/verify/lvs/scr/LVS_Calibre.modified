MOM_field4 = metal4i AND MOMDMY4 
ngate_nthin_rf = nthin INTERACT ngate_rf1 
aux_ngate_nthin_6t = DFM PROPERTY rfdmy6t_odnum ngate_nthin_rf  OVERLAP
		       [ count_num = COUNT(ngate_nthin_rf)]

//***** Define connectivity/via layer -- n_gpoly_srm ****
n_gpoly_srm_all = npoly_co_srm NOT n_fpoly_srm 
