	,spotl2,spotl1,spot,spotr1,spotr2,spobl2,spobl1,spob,spobr1,spobr2
#ENDIF
   dfm_flag = 1
   LR_EXT = MOS_LR_EXT
   TOP_EXT = 0
   BOT_EXT = NMOS_BOT_EXT
   SCALE = PRESCALE
   W = (perimeter_coincide(nch_lnvt_dnw_mac_gate, tndiff ) + perimeter_inside(nch_lnvt_dnw_mac_gate, tndiff)) / 2
   L = area(nch_lnvt_dnw_mac_gate) / W
   #IFDEF MATCHFLAG
      len_aux = perimeter(matching_aux)/2 - MINGRID_RECT1_UNIT
      matchingflag = 0.0
