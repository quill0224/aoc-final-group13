gate_and_p96b = gate_p96 AND PO_P96 
gate_and_p96 = gate_and_p96b NOT PO_P130 
ppitch_aux10 = RECTANGLES MINGRID_RECT1 MINGRID_RECT2 1000 INSIDE OF LAYER gate_and_p96
ppitch_auxa = ppitch_aux00 OR ppitch_aux10 
gate_and_p130a = gate_p96 NOT PO_P96 
gate_and_p130 = gate_and_p130a AND PO_P130 
ppitch_aux20 = RECTANGLES MINGRID_RECT1 MINGRID_RECT3 1000 INSIDE OF LAYER gate_and_p130
ppitch_aux = ppitch_auxa OR ppitch_aux20 

