DEVICE efuse_mx m2efuse M2(PLUS) M2(MINUS) (PLUS MINUS) [
property l,w
  w = perimeter_coincide(m2efuse,M2)/2
  l = area(m2efuse)/w
]
TRACE PROPERTY efuse_mx w w RES_Werr
TRACE PROPERTY efuse_mx l l RES_Lerr

DEVICE efuse_vx v2efuse v2efuse_p(PLUS) v2efuse_m(MINUS) <m2vfusex> <v2fuse> [
property l,w,lv,wv
  w = perimeter_coincide(m2vfusex,v2efuse_p)
  l = area(m2vfusex)/w
  wv = perimeter_coincide(v2fuse,m2vfusex)
  lv = area(v2fuse)/wv
]
TRACE PROPERTY efuse_vx w w RES_Werr
TRACE PROPERTY efuse_vx l l RES_Lerr
TRACE PROPERTY efuse_vx wv wv RES_Werr
TRACE PROPERTY efuse_vx lv lv RES_Lerr

#IFDEF MIMCAP_TYPE 
ctm_8 = ctm NOT ctm_open
cbm_8 = cbm NOT cbm_open
RCTMa = mim_top AND CTMDMY8
RCTMb = RCTMa NOT INTERACT CTMDMY9
RCTM8 = RCTMb INTERACT VIA7i
RCBM = cbm_8 INTERACT RCTM8
RCTM = ctm_8 INTERACT RCTM8
OCBM = RCBM NOT RCTM
ctm_via7a = RCTM8 AND VIA7i
ctm_via7b = ctm_via7a NOT ctm_open
ctm_via7  = ctm_via7b NOT cbm_open
cbm_via7a = OCBM AND VIA7i
cbm_via7  = cbm_via7a NOT cbm_open
tvia1   = VIA7i NOT ctm_via7
VIA7  = tvia1 NOT cbm_via7		// normal VIA7 will located on region of [ctm_open && cbm_open]
VIA8   = COPY VIA8i
//CONNECT STATEMENT
CONNECT M8 ctm_8 BY ctm_via7
CONNECT M8 cbm_8 BY cbm_via7
#ELSE
ctm_9 = ctm NOT ctm_open
cbm_9 = cbm NOT cbm_open
RCTMa = mim_top AND CTMDMY9
RCTMb = RCTMa NOT INTERACT CTMDMY8
RCTM9 = RCTMb INTERACT VIA8i
RCBM = cbm_9 INTERACT RCTM9
RCTM = ctm_9 INTERACT RCTM9
OCBM = RCBM NOT RCTM
ctm_via8a = RCTM9 AND VIA8i
ctm_via8b = ctm_via8a NOT ctm_open
ctm_via8  = ctm_via8b NOT cbm_open
cbm_via8a = OCBM AND VIA8i
cbm_via8  = cbm_via8a NOT cbm_open
tvia1   = VIA8i NOT ctm_via8
VIA8   = tvia1 NOT cbm_via8
VIA7  = COPY VIA7i 
//CONNECT STATEMENT
CONNECT M9 ctm_9 BY ctm_via8
CONNECT M9 cbm_9 BY cbm_via8
#ENDIF

#IFDEF MIMCAP_TYPE
DEVICE mimcap_sin RCTM8 ctm_8(TOP) cbm_8(BOT) [
  property area_mim
  A_CAP = area(RCTM8)
  area_mim = A_CAP
  P_CAP = perimeter(RCTM8)
  P_2_CAP = P_CAP * P_CAP
  AC4 = A_CAP * 16
  KKK = P_2_CAP-AC4
  IF(KKK<0) {
  KKK=0
  }
  SQ = sqrt(KKK)
  lt = (P_CAP+SQ)/4
  wt = (P_CAP-SQ)/4
]
#ELSE
DEVICE mimcap_sin RCTM9 ctm_9(TOP) cbm_9(BOT) [
  property area_mim
  A_CAP = area(RCTM9)
  area_mim = A_CAP
  P_CAP = perimeter(RCTM9)
  P_2_CAP = P_CAP * P_CAP
  AC4 = A_CAP * 16
  KKK = P_2_CAP-AC4
  IF(KKK<0) {
  KKK=0
  }
  SQ = sqrt(KKK)
  lt = (P_CAP+SQ)/4
  wt = (P_CAP-SQ)/4
]
#ENDIF
TRACE PROPERTY mimcap_sin area_mim area_mim MIMCAP_Aerr








#IFDEF RC_DECK
DEVICE cfmom_wo_p80 fmom1_reg_nw_p80 M1(PLUS) M1(MINUS) nxwell(BULK) <MOM_field1> <MOMDMY_VAP> <MOMDMY_MXA> <MOMDMY_MXD> <MOM_LAYER_8> <SHIELD_LAYER> <mom1_extc> <MOM_hole1> <grflag_aux> <mom_SOB> (PLUS MINUS) [
#ELSE
DEVICE cfmom_wo_p80 fmom1_reg_nw_p80 M1(PLUS) M1(MINUS) nxwell(BULK) <MOM_field1> <MOMDMY_VAP> <MOMDMY_MXA> <MOMDMY_MXD> <MOM_LAYER_8> <SHIELD_LAYER> <mom1_extc> <MOM_hole1> <grflag_aux> (PLUS MINUS) [
#ENDIF
    property nr,lr,stm,spm,dmflag,vapmod,n_mxa,mxd_flag,shield,grflag
  #IFDEF RC_DECK
    ,gdis_t,gdis_b,gdis_l,gdis_r
  #ENDIF

    nr      = count(MOM_field1)
    w       = perimeter_coincide(MOM_field1, fmom1_reg_nw_p80) / nr
    ftip    = AREA(mom1_extc) / nr / w
    s       = perimeter_coincide(MOM_hole1, fmom1_reg_nw_p80) / (nr-1) / 2
    lr      = perimeter(MOM_hole1) / 2 / (nr-1) - s - 2 * ftip
    stm     = 1
    spm     = (perimeter(MOM_LAYER_8)/2 - (1e-9)) / 1e-9
    vapmod1 = ( perimeter(MOMDMY_VAP) * (1e+6) ) / 2 - 0.05
    if( vapmod1 < 0.051 ) {
	vapmod = 0
    } else {
	vapmod = vapmod1 / 0.1
    }
    mxd_flag1 = ( perimeter(MOMDMY_MXD) * (1e+6) ) / 2 - 0.05
    if( mxd_flag1 < 0.051 ) {
	mxd_flag = 0
    } else {
	mxd_flag = mxd_flag1 / 0.1
    }
    if ( area(grflag_aux) > area(MOMDMY_VAP) ) { grflag = 0 } ELSE { grflag = 1 }
  #IFDEF RC_DECK
   gdis_t = 0
   gdis_b = 0
   gdis_l = 0
   gdis_r = 0
   RFX_1 = DFM_VEC_VAL( mom_SOB, "PER_1" )
   RFX_2 = DFM_VEC_VAL( mom_SOB, "PER_2" )
   RFY_1 = DFM_VEC_VAL( mom_SOB, "PAR_1" )
   RFY_2 = DFM_VEC_VAL( mom_SOB, "PAR_2" )
   gdis_t = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_1, UNIT_LENGTH())
   gdis_b = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_2, UNIT_LENGTH())
   gdis_l = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_1, UNIT_LENGTH())
   gdis_r = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_2, UNIT_LENGTH())
   if ( gdis_t == 0.00015  &&  gdis_b == 0.00015  &&  gdis_l == 0.00015  && gdis_r == 0.00015 ) {
     if ( grflag == 1 ) {
        gdis_t = 0.175e-6
        gdis_b = 0.175e-6
        gdis_l = 0.102e-6
        gdis_r = 0.102e-6
     }
   } else {
        gdis_t = gdis_t - 0.12e-6
        gdis_b = gdis_b - 0.12e-6
        gdis_l = gdis_l + 0.005e-6
        gdis_r = gdis_r + 0.005e-6
   }
  #ENDIF


    n_mxa1    = ( perimeter(MOMDMY_MXA) * (1e+6) ) / 2 - 0.05
    if( n_mxa1 < 0.051 ) { 
	n_mxa = 0
    } else {
	n_mxa = n_mxa1 / 0.1
    }
    dmflag = 0
    shield = (perimeter(SHIELD_LAYER)/2 - (1e-8)) / 1e-8
]
#IFDEF RC_DECK
DEVICE cfmom_wo_p80 fmom1_reg_pw_p80 M1(PLUS) M1(MINUS) psub(BULK) <MOM_field1> <MOMDMY_VAP> <MOMDMY_MXA> <MOMDMY_MXD> <MOM_LAYER_8> <SHIELD_LAYER> <mom1_extc> <MOM_hole1> <grflag_aux> <mom_SOB> (PLUS MINUS) [
#ELSE
DEVICE cfmom_wo_p80 fmom1_reg_pw_p80 M1(PLUS) M1(MINUS) psub(BULK) <MOM_field1> <MOMDMY_VAP> <MOMDMY_MXA> <MOMDMY_MXD> <MOM_LAYER_8> <SHIELD_LAYER> <mom1_extc> <MOM_hole1> <grflag_aux> (PLUS MINUS) [
#ENDIF
    property nr,lr,stm,spm,dmflag,vapmod,n_mxa,mxd_flag,shield,grflag
  #IFDEF RC_DECK
    ,gdis_t,gdis_b,gdis_l,gdis_r
  #ENDIF

    nr      = count(MOM_field1)
    w       = perimeter_coincide(MOM_field1, fmom1_reg_pw_p80) / nr
    ftip    = AREA(mom1_extc) / nr / w
    s       = perimeter_coincide(MOM_hole1, fmom1_reg_pw_p80) / (nr-1) / 2
    lr      = perimeter(MOM_hole1) / 2 / (nr-1) - s - 2 * ftip
    stm     = 1
    spm     = (perimeter(MOM_LAYER_8)/2 - (1e-9)) / 1e-9
    vapmod1 = ( perimeter(MOMDMY_VAP) * (1e+6) ) / 2 - 0.05
    if( vapmod1 < 0.051 ) {
	vapmod = 0
    } else {
	vapmod = vapmod1 / 0.1
    }
    mxd_flag1 = ( perimeter(MOMDMY_MXD) * (1e+6) ) / 2 - 0.05
    if( mxd_flag1 < 0.051 ) {
	mxd_flag = 0
    } else {
	mxd_flag = mxd_flag1 / 0.1
    }
    if ( area(grflag_aux) > area(MOMDMY_VAP) ) { grflag = 0 } ELSE { grflag = 1 }
  #IFDEF RC_DECK
   gdis_t = 0
   gdis_b = 0
   gdis_l = 0
   gdis_r = 0
   RFX_1 = DFM_VEC_VAL( mom_SOB, "PER_1" )
   RFX_2 = DFM_VEC_VAL( mom_SOB, "PER_2" )
   RFY_1 = DFM_VEC_VAL( mom_SOB, "PAR_1" )
   RFY_2 = DFM_VEC_VAL( mom_SOB, "PAR_2" )
   gdis_t = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_1, UNIT_LENGTH())
   gdis_b = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_2, UNIT_LENGTH())
   gdis_l = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_1, UNIT_LENGTH())
   gdis_r = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_2, UNIT_LENGTH())
   if ( gdis_t == 0.00015  &&  gdis_b == 0.00015  &&  gdis_l == 0.00015  && gdis_r == 0.00015 ) {
     if ( grflag == 1 ) {
        gdis_t = 0.175e-6
        gdis_b = 0.175e-6
        gdis_l = 0.102e-6
        gdis_r = 0.102e-6
     }
   } else {
        gdis_t = gdis_t - 0.12e-6
        gdis_b = gdis_b - 0.12e-6
        gdis_l = gdis_l + 0.005e-6
        gdis_r = gdis_r + 0.005e-6
   }
  #ENDIF


    n_mxa1    = ( perimeter(MOMDMY_MXA) * (1e+6) ) / 2 - 0.05
    if( n_mxa1 < 0.051 ) { 
	n_mxa = 0
    } else {
	n_mxa = n_mxa1 / 0.1
    }
    dmflag = 0
    shield = (perimeter(SHIELD_LAYER)/2 - (1e-8)) / 1e-8
]

#IFDEF RC_DECK
DEVICE cfmom_wo_p80_odd fmom1_reg_nw_p80_odd mom1p_odd(PLUS) mom1m_odd(MINUS) nxwell(BULK) <MOM_field1> <MOMDMY_VAP> <MOMDMY_MXA> <MOMDMY_MXD> <MOM_LAYER_8> <SHIELD_LAYER> <mom1_extc> <MOM_hole1> <grflag_aux> <mom_SOB>  [
