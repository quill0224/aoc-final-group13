    property nr,lr,stm,spm,dmflag,vapmod,n_mxa,mxd_flag,shield,grflag
  #IFDEF RC_DECK
    ,gdis_t,gdis_b,gdis_l,gdis_r
  #ENDIF

    nr      = count(MOM_field1)
    w       = perimeter_coincide(MOM_field1, fmom1_reg_nw_p80_odd) / nr
    ftip    = AREA(mom1_extc) / nr / w
    s       = perimeter_coincide(MOM_hole1, fmom1_reg_nw_p80_odd) / (nr-1) / 2
