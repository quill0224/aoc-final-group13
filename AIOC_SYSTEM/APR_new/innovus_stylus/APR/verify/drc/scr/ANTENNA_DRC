ACC_VIA7 = NET AREA RATIO VIA7 M7_DIO M7_GOX SF_GATE_VIA DF_GATE_VIA GATE_VIA >= 0 ACCUMULATE ACC_VIA6
       [(!AREA(M7_DIO) * (AREA(VIA7)/(AREA(SF_GATE_VIA)*SF_GATE_FACTOR + AREA(DF_GATE_VIA)*DF_GATE_FACTOR)) + 
