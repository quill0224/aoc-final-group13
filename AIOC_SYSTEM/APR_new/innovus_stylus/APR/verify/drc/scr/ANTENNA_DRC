        !!AREA(M7_DIO) * !AREA(M7_GOX) * AREA(VIA7)/((AREA(SF_GATE_VIA)*SF_GATE_FACTOR + AREA(DF_GATE_VIA)*DF_GATE_FACTOR)+AREA(M7_DIO)*DIO_FACTOR*5))] 


VIA7.R.13 { @ Maximum area ratio of M7 to VIA7 in the same net [connects to gate with area > 10700 um2, and does not connect to OD] <= 350000
   NET AREA RATIO M7 VIA7 SF_GATE_VIA DF_GATE_VIA GATE_VIA M7_DIO > 350000
   [!AREA(M7_DIO)*!~((AREA(SF_GATE_VIA)*SF_GATE_FACTOR + AREA(DF_GATE_VIA)*DF_GATE_FACTOR)-10700)*(AREA(M7)/AREA(VIA7))]  
   RDB VIA7.R.13.rep M7 VIA7 SF_GATE_VIA DF_GATE_VIA BY LAYER
}


