  NET AREA RATIO VIA7 VIA6 VIA5 VIA4 VIA3 VIA2 VIA1 VIA0 HV_GATE M7_DIO SF_GATE_VIA DF_GATE_VIA ACT_GATE GATE_VIA > 0 ACCUMULATE ACC_VIA6 ACC_VIA5 ACC_VIA4 ACC_VIA3 ACC_VIA2 ACC_VIA1 ACC_VIA0
      [
        !!AREA(ACT_GATE)*!AREA(M7_DIO) * !!AREA(VIA7) * !!AREA(VIA6) * !!AREA(VIA5) * !!AREA(VIA4) * !!AREA(VIA3) * !!AREA(VIA2) * !!AREA(VIA1) * !!AREA(VIA0) * !!AREA(GATE_VIA) * !!AREA(HV_GATE) * ( AREA(VIA7)/(AREA(SF_GATE_VIA)*SF_GATE_FACTOR + AREA(DF_GATE_VIA)*DF_GATE_FACTOR) - 50 )
        - (!!AREA(M7_DIO)+!AREA(VIA7)+!AREA(GATE_VIA)+!AREA(HV_GATE)+!AREA(ACT_GATE)) * LargeNumber
      ] RDB A.R.9.VIA7.rep VIA7 VIA6 VIA5 VIA4 VIA3 VIA2 VIA1 VIA0 GATE_VIA SF_GATE_VIA DF_GATE_VIA ACT_GATE BY LAYER
}
