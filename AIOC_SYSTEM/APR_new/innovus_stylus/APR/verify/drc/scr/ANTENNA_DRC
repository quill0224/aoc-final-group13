  NET AREA RATIO HV_GATE M6 M6_DIO SF_GATE DF_GATE ACT_GATE  > A_R_6_2  
   [!!AREA(M6) * !!AREA(ACT_GATE) * !AREA(M6_DIO) * !!AREA(HV_GATE)*(AREA(SF_GATE)*SF_GATE_FACTOR + AREA(DF_GATE)*DF_GATE_FACTOR)]
