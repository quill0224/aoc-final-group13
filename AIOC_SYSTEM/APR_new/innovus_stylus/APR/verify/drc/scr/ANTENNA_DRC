M3_DIO = NET AREA SD >= DIO_AREA
M3_GOX = NET AREA RATIO GATE_VIA SF_GATE_VIA DF_GATE_VIA > GOX_AREA
		[
			!!AREA(GATE_VIA) * (AREA(SF_GATE_VIA)*SF_GATE_FACTOR + AREA(DF_GATE_VIA)*DF_GATE_FACTOR)
		]
M3_GATE_L1000 = NET AREA RATIO GATE_VIA SF_GATE_VIA DF_GATE_VIA >= GATE_AREA_L1000
		[
			!!AREA(GATE_VIA) * (AREA(SF_GATE_VIA)*SF_GATE_FACTOR + AREA(DF_GATE_VIA)*DF_GATE_FACTOR)
		]

A.R.6__A.R.6.1__A.R.8:M3 { @ (cumulative M1~M3 area / gate area) <= (1000 in OD2, 5000 not in OD2) (without diode)
                  @ (cumulative M1~M3 area / gate area) <= (250000 * (gate area) ^ -0.8 in OD2) (without diode, gate area >= 1000 um2)
		  @ (cumulative M1~M3 area / gate area) <= 5000 * (1 + diode area * 0.5 / gate area) (with diode, gate area <= 0.03 um2)
		  @ (cumulative M1~M3 area / gate area) <= 5000 * (1 + diode area * 0.5 / gate area + 7.6 / gate area) (with diode, gate area > 0.03 um2)
  NET AREA RATIO M3 M2 M1 M3_DIO M3_GOX M3_GATE_L1000 HV_GATE SF_GATE DF_GATE ACT_GATE GATE > 0 ACCUMULATE ACC_M2 ACC_M1 
       [
         !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(ACT_GATE)*!!AREA(GATE) *
	   (!AREA(M3_DIO) * (!!AREA(HV_GATE)*(!!AREA(M3_GATE_L1000)*(AREA(M3)/(AREA(SF_GATE)*SF_GATE_FACTOR + AREA(DF_GATE)*DF_GATE_FACTOR)-250000*((AREA(SF_GATE)*SF_GATE_FACTOR + AREA(DF_GATE)*DF_GATE_FACTOR)^(-0.8)))+
					      !AREA(M3_GATE_L1000)*(AREA(M3)/(AREA(SF_GATE)*SF_GATE_FACTOR + AREA(DF_GATE)*DF_GATE_FACTOR)-1000)) +
	                     !AREA(HV_GATE)*(AREA(M3)/(AREA(SF_GATE)*SF_GATE_FACTOR + AREA(DF_GATE)*DF_GATE_FACTOR)-5000)) +
	    !!AREA(M3_DIO) * !!AREA(M3_GOX) * ( AREA(M3)/((AREA(SF_GATE)*SF_GATE_FACTOR + AREA(DF_GATE)*DF_GATE_FACTOR)+AREA(M3_DIO)*0.5+7.6)-5000 ) +
	    !!AREA(M3_DIO) * !AREA(M3_GOX) * ( AREA(M3)/((AREA(SF_GATE)*SF_GATE_FACTOR + AREA(DF_GATE)*DF_GATE_FACTOR)+AREA(M3_DIO)*0.5)-5000 ))
	  - (!AREA(M3)+!AREA(GATE)+!AREA(ACT_GATE)) * LargeNumber 
       ] RDB A.R.6__A.R.6.1__A.R.8.M3.rep M3 M2 M1 M3_DIO M3_GOX M3_GATE_L1000 HV_GATE GATE SF_GATE DF_GATE ACT_GATE BY LAYER
}
