A.R.6__A.R.6.1__A.R.8:M8 { @ (cumulative M1~M8 area / gate area) <= (1000 in OD2, 5000 not in OD2) (without diode)
                  @ (cumulative M1~M8 area / gate area) <= (250000 * (gate area) ^ -0.8 in OD2) (without diode, gate area >= 1000 um2)
		  @ (cumulative M1~M8 area / gate area) <= 5000 * (1 + diode area * 0.5 / gate area) (with diode, gate area <= 0.03 um2)
		  @ (cumulative M1~M8 area / gate area) <= 5000 * (1 + diode area * 0.5 / gate area + 7.6 / gate area) (with diode, gate area > 0.03 um2)
  NET AREA RATIO M8 M7 M6 M5 M4 M3 M2 M1 M8_DIO M8_GOX M8_GATE_L1000 HV_GATE SF_GATE DF_GATE ACT_GATE GATE > 0 ACCUMULATE ACC_M7 ACC_M6 ACC_M5 ACC_M4 ACC_M3 ACC_M2 ACC_M1 
       [
         !!AREA(M8) * !!AREA(M7) * !!AREA(M6) * !!AREA(M5) * !!AREA(M4) * !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(ACT_GATE)*!!AREA(GATE) *
	   (!AREA(M8_DIO) * (!!AREA(HV_GATE)*(!!AREA(M8_GATE_L1000)*(AREA(M8)/(AREA(SF_GATE)*SF_GATE_FACTOR + AREA(DF_GATE)*DF_GATE_FACTOR)-250000*((AREA(SF_GATE)*SF_GATE_FACTOR + AREA(DF_GATE)*DF_GATE_FACTOR)^(-0.8)))+
					      !AREA(M8_GATE_L1000)*(AREA(M8)/(AREA(SF_GATE)*SF_GATE_FACTOR + AREA(DF_GATE)*DF_GATE_FACTOR)-1000)) +
	                     !AREA(HV_GATE)*(AREA(M8)/(AREA(SF_GATE)*SF_GATE_FACTOR + AREA(DF_GATE)*DF_GATE_FACTOR)-5000)) +
	    !!AREA(M8_DIO) * !!AREA(M8_GOX) * ( AREA(M8)/((AREA(SF_GATE)*SF_GATE_FACTOR + AREA(DF_GATE)*DF_GATE_FACTOR)+AREA(M8_DIO)*0.5+7.6)-5000 ) +
	    !!AREA(M8_DIO) * !AREA(M8_GOX) * ( AREA(M8)/((AREA(SF_GATE)*SF_GATE_FACTOR + AREA(DF_GATE)*DF_GATE_FACTOR)+AREA(M8_DIO)*0.5)-5000 ))
	  - (!AREA(M8)+!AREA(GATE)+!AREA(ACT_GATE)) * LargeNumber 
       ] RDB A.R.6__A.R.6.1__A.R.8.M8.rep M8 M7 M6 M5 M4 M3 M2 M1 M8_DIO M8_GOX M8_GATE_L1000 HV_GATE GATE SF_GATE DF_GATE ACT_GATE BY LAYER
